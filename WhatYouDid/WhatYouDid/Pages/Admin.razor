@page "/admin"
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using System.ComponentModel.DataAnnotations
@using WhatYouDid.Data
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]

@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager NavigationManager

<PageTitle>Admin</PageTitle>

<h1>Administration</h1>

<p class="text-muted">Only users in the "Admin" role can access this page.</p>

<hr />

<h2>Users</h2>

@if (users is null)
{
    <p>Loading users...</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Email</th>
                <th>User name</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in users)
            {
                var model = resetModels[user.Id];
                <tr>
                    <td>@user.Email</td>
                    <td>@user.UserName</td>
                    <td>
                        <EditForm Model="model" OnValidSubmit="() => ResetPasswordAsync(user)">
                            <div class="input-group">
                                <InputText @bind="model.NewPassword" type="password" class="form-control" placeholder="New password" />
                                <button class="btn btn-outline-secondary" type="submit">Reset</button>
                            </div>
                        </EditForm>
                        @if (resetStatus.TryGetValue(user.Id, out var msg) && msg is not null)
                        {
                            <div class="small mt-1">@msg</div>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<hr />

<h2>Create user</h2>

<EditForm Model="createModel" OnValidSubmit="CreateUserAsync">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label">Email</label>
        <InputText @bind="createModel.Email" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Password</label>
        <InputText @bind="createModel.Password" type="password" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Confirm password</label>
        <InputText @bind="createModel.ConfirmPassword" type="password" class="form-control" />
    </div>

    <button class="btn btn-primary" type="submit">Create user</button>

    @if (!string.IsNullOrEmpty(createStatus))
    {
        <div class="mt-2">@createStatus</div>
    }
</EditForm>

@code {
    private List<ApplicationUser>? users;

    private Dictionary<string, ResetModel> resetModels = new();
    private Dictionary<string, string?> resetStatus = new();

    private CreateModel createModel = new();
    private string? createStatus;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        var q = UserManager.Users;
        users = await q.ToListAsync();

        // Ensure a reset model exists for each user so binding works
        foreach (var u in users)
        {
            if (!resetModels.ContainsKey(u.Id))
            {
                resetModels[u.Id] = new ResetModel();
            }
        }
    }

    private async Task CreateUserAsync()
    {
        createStatus = null;

        if (string.IsNullOrWhiteSpace(createModel.Email) || string.IsNullOrWhiteSpace(createModel.Password))
        {
            createStatus = "Email and password are required.";
            return;
        }

        var user = new ApplicationUser { UserName = createModel.Email, Email = createModel.Email };
        var result = await UserManager.CreateAsync(user, createModel.Password);
        if (result.Succeeded)
        {
            createStatus = "User created.";
            await LoadUsersAsync();
            StateHasChanged();
        }
        else
        {
            createStatus = "Error: " + string.Join(", ", result.Errors.Select(e => e.Description));
        }
    }

    private async Task ResetPasswordAsync(ApplicationUser user)
    {
        resetStatus[user.Id] = null;
        var model = resetModels[user.Id];
        if (string.IsNullOrWhiteSpace(model.NewPassword))
        {
            resetStatus[user.Id] = "Password is required.";
            return;
        }

        // Generate reset token and apply it
        var token = await UserManager.GeneratePasswordResetTokenAsync(user);
        var result = await UserManager.ResetPasswordAsync(user, token, model.NewPassword);
        if (result.Succeeded)
        {
            resetStatus[user.Id] = "Password reset.";
            model.NewPassword = string.Empty;
        }
        else
        {
            resetStatus[user.Id] = "Error: " + string.Join(", ", result.Errors.Select(e => e.Description));
        }
    }

    private sealed class ResetModel
    {
        [Required]
        public string? NewPassword { get; set; }
    }

    private sealed class CreateModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required]
        [StringLength(100, MinimumLength = 6)]
        public string Password { get; set; } = string.Empty;

        [Compare("Password", ErrorMessage = "The password and confirmation password do not match.")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
