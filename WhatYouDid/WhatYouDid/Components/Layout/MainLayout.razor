@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

@{
    // The workout page uses pure WASM — skip the InteractiveServer RadzenComponents
    // so no SignalR circuit is created, preventing reconnect prompts on mobile.
    var isWorkoutPage = NavigationManager.ToBaseRelativePath(NavigationManager.Uri)
        .StartsWith("workout/", StringComparison.OrdinalIgnoreCase);
}

<div class="page">

    @if (!isWorkoutPage)
    {
        <RadzenComponents @rendermode="InteractiveServer" />
    }
    else 
    {
        <RadzenComponents @rendermode="InteractiveWebAssembly" />
    }

    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <!--<div class="top-row px-4">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
		</div>-->

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
