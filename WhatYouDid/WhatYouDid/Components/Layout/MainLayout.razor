@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

@{
    // The workout page uses pure WASM — skip the InteractiveServer RadzenComponents
    // so no SignalR circuit is created, preventing reconnect prompts on mobile.
    var isWorkoutPage = NavigationManager.ToBaseRelativePath(NavigationManager.Uri)
        .StartsWith("workout/", StringComparison.OrdinalIgnoreCase);
}

<div class="page">

    @if (!isWorkoutPage)
    {
        <RadzenComponents @rendermode="InteractiveServer" />
    }
    else
    {
        <RadzenComponents @rendermode="InteractiveWebAssembly" />
    }

    <header class="top-bar">
        <a href="/" class="top-bar-brand">
            <RadzenButton Icon="home" Variant="Variant.Flat" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" />
            <span>What You Did</span>
        </a>
    </header>

    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
