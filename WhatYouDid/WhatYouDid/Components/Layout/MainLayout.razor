@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

@{
    // The workout page uses pure WASM — skip the InteractiveServer MudBlazor providers
    // so no SignalR circuit is created, preventing reconnect prompts on mobile.
    var isWorkoutPage = NavigationManager.ToBaseRelativePath(NavigationManager.Uri)
        .StartsWith("workout/", StringComparison.OrdinalIgnoreCase);
}

<MudThemeProvider Theme="_theme" />

@if (!isWorkoutPage)
{
    <MudPopoverProvider />
    <MudDialogProvider />
    <MudSnackbarProvider />
}

<div class="page">
    <header class="top-bar">
        <a href="/" class="top-bar-brand" data-enhance-nav="@(isWorkoutPage ? "false" : null)">
            <MudIconButton Icon="@Icons.Material.Filled.Home" Size="Size.Small" />
            <span>What You Did</span>
        </a>
    </header>

    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private MudTheme _theme = new MudTheme
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1b6ec2",
            Secondary = "#3a0647",
        }
    };
}
