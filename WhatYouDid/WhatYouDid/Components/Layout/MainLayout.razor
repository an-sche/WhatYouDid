@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" IsDarkMode="true" />

<div class="page">
    <header class="top-bar">
        <a href="/" class="top-bar-brand" data-enhance-nav="false">
            <MudIconButton Icon="@Icons.Material.Filled.Home" Size="Size.Small" />
            <span>What You Did</span>
        </a>
    </header>

    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private MudTheme _theme = new MudTheme
    {
        PaletteDark = new PaletteDark
        {
            Primary = "#39FF14",
            PrimaryContrastText = "#000000",
            Secondary = "#FF2D78",
            SecondaryContrastText = "#000000",
            Background = "#1A1A1A",
            BackgroundGray = "#141414",
            Surface = "#2D2D2D",
            AppbarBackground = "#0D0D0D",
            AppbarText = "#FFFFFF",
            DrawerBackground = "#1A1A1A",
            DrawerText = "#FFFFFF",
            TextPrimary = "#F0F0F0",
            TextSecondary = "rgba(255,255,255,0.6)",
            ActionDefault = "rgba(255,255,255,0.54)",
            LinesDefault = "#3D3D3D",
            TableLines = "#3D3D3D",
            Divider = "#3D3D3D",
        }
    };
}
