@using WhatYouDid.Shared

@inject IWorkoutService WorkoutService
@inject IDialogService DialogService

<MudCard Class="mb-2">
    <MudCardContent>
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center"
                  Style="cursor: pointer" @onclick="ToggleCollapsed">
            <MudStack Spacing="0">
                <MudText Typo="Typo.body1" Style="font-weight: 600">@Workout.RoutineName</MudText>
                <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary)">
                    @Workout.StartTime.ToString("MMM d, yyyy h:mm tt")
                    @if (Workout.EndTime is { } endTime)
                    {
                        var duration = endTime - Workout.StartTime;
                        <text> (@((int)duration.TotalHours > 0 ? $"{(int)duration.TotalHours}h {duration.Minutes}m" : $"{duration.Minutes}m"))</text>
                    }
                </MudText>
            </MudStack>
            <span @onclick:stopPropagation="true">
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                               Size="Size.Medium" OnClick="DeleteWorkout" />
            </span>
        </MudStack>

        @if (!collapsed && detail is not null)
        {
            <MudStack Spacing="0" Class="mt-3">
                @foreach (var exercise in detail.WorkoutExercises ?? [])
                {
                    <MudStack Spacing="1" Style="padding: 10px 0; border-top: 1px solid var(--mud-palette-divider)">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.body2" Style="font-weight: 600">
                                @exercise.Sequence. @exercise.ExerciseName
                            </MudText>
                            @if (editingExercise == exercise)
                            {
                                <MudStack Row="true" Spacing="1">
                                    <MudButton StartIcon="@Icons.Material.Filled.Save" Disabled="saving"
                                               OnClick="() => SaveExerciseEdit(exercise)"
                                               Color="Color.Primary" Size="Size.Small" Variant="Variant.Filled">Save</MudButton>
                                    <MudButton StartIcon="@Icons.Material.Filled.Close" OnClick="CancelExerciseEdit"
                                               Color="Color.Secondary" Size="Size.Small" Variant="Variant.Filled">Cancel</MudButton>
                                </MudStack>
                            }
                            else
                            {
                                <MudButton StartIcon="@Icons.Material.Filled.Edit"
                                           OnClick="() => { editingExercise = exercise; _expandedAlts.Clear(); }"
                                           Size="Size.Small" Variant="Variant.Outlined"
                                           Disabled="saving">Edit</MudButton>
                            }
                        </MudStack>

                        @if (editingExercise == exercise)
                        {
                            @for (int i = 0; i < exercise.Sets; i++)
                            {
                                var setIndex = i;
                                <MudStack Spacing="1">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Style="flex-wrap: wrap">
                                        <MudText Typo="Typo.caption" Style="min-width: 40px">Set @(setIndex + 1)</MudText>
                                        @if (exercise.HasReps)
                                        {
                                            <MudNumericField T="int?" @bind-Value="exercise.Reps[setIndex]" Style="width: 65px" Variant="Variant.Outlined" />
                                            <MudText Typo="Typo.caption">reps</MudText>
                                        }
                                        @if (exercise.HasWeights)
                                        {
                                            <MudNumericField T="int?" @bind-Value="exercise.Weights[setIndex]" Style="width: 65px" Variant="Variant.Outlined" />
                                            <MudText Typo="Typo.caption">lbs</MudText>
                                        }
                                        @if (exercise.HasDurations)
                                        {
                                            <MudNumericField T="int?" @bind-Value="exercise.Durations[setIndex]" Style="width: 65px" Variant="Variant.Outlined" />
                                            <MudText Typo="Typo.caption">sec</MudText>
                                        }
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined"
                                            StartIcon="@(IsAltExpanded(setIndex) || HasAltData(exercise, setIndex) ? Icons.Material.Filled.Remove : Icons.Material.Filled.Add)"
                                            OnClick="@(() => ToggleAlt(setIndex))">Alt</MudButton>
                                    </MudStack>

                                    @if (IsAltExpanded(setIndex) || HasAltData(exercise, setIndex))
                                    {
                                        <MudStack Spacing="1"
                                            Style="border-left: 2px solid var(--mud-palette-secondary-lighten); padding-left: 8px">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Style="flex-wrap: wrap">
                                                <MudText Typo="Typo.caption" Style="min-width: 40px; color: var(--mud-palette-text-secondary)">Alt</MudText>
                                                @if (exercise.HasReps)
                                                {
                                                    <MudNumericField T="int?" @bind-Value="exercise.AlternateReps[setIndex]" Style="width: 65px" Variant="Variant.Outlined" />
                                                    <MudText Typo="Typo.caption">reps</MudText>
                                                }
                                                @if (exercise.HasWeights)
                                                {
                                                    <MudNumericField T="int?" @bind-Value="exercise.AlternateWeights[setIndex]" Style="width: 65px" Variant="Variant.Outlined" />
                                                    <MudText Typo="Typo.caption">lbs</MudText>
                                                }
                                                @if (exercise.HasDurations)
                                                {
                                                    <MudNumericField T="int?" @bind-Value="exercise.AlternateDurations[setIndex]" Style="width: 65px" Variant="Variant.Outlined" />
                                                    <MudText Typo="Typo.caption">sec</MudText>
                                                }
                                            </MudStack>
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                <MudText Typo="Typo.caption" Style="min-width: 40px; color: var(--mud-palette-text-secondary)">Note</MudText>
                                                <MudTextField @bind-Value="exercise.Notes[setIndex]" Placeholder="note" Style="flex: 1" Variant="Variant.Outlined" />
                                            </MudStack>
                                        </MudStack>
                                    }
                                </MudStack>
                            }
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Style="white-space: pre-line; color: var(--mud-palette-text-secondary)">
                                @exercise.Review
                            </MudText>
                        }
                    </MudStack>
                }
            </MudStack>
        }
    </MudCardContent>
</MudCard>

@code {
    [Parameter, EditorRequired] public required WorkoutListItemDto Workout { get; set; }
    [Parameter] public EventCallback OnDeleted { get; set; }

    bool collapsed = true;
    WorkoutDto? detail;
    WorkoutExerciseDto? editingExercise;
    bool saving = false;
    HashSet<int> _expandedAlts = new();

    bool IsAltExpanded(int setIndex) => _expandedAlts.Contains(setIndex);

    void ToggleAlt(int setIndex)
    {
        if (!_expandedAlts.Remove(setIndex))
            _expandedAlts.Add(setIndex);
    }

    bool HasAltData(WorkoutExerciseDto exercise, int setIndex) =>
        (exercise.AlternateReps.Length > setIndex && exercise.AlternateReps[setIndex] != null)
        || (exercise.AlternateWeights.Length > setIndex && exercise.AlternateWeights[setIndex] != null)
        || (exercise.AlternateDurations.Length > setIndex && exercise.AlternateDurations[setIndex] != null)
        || (exercise.Notes.Length > setIndex && !string.IsNullOrEmpty(exercise.Notes[setIndex]));

    async Task ToggleCollapsed()
    {
        collapsed = !collapsed;
        if (!collapsed)
            await LoadDetail();
    }

    async Task LoadDetail()
    {
        if (detail is null)
            detail = await WorkoutService.GetCompletedWorkoutDtoAsync(Workout.WorkoutId);
    }

    async Task SaveExerciseEdit(WorkoutExerciseDto exercise)
    {
        if (detail is null) return;
        saving = true;
        StateHasChanged();
        try
        {
            await WorkoutService.UpdateWorkoutExerciseAsync(detail.WorkoutId, exercise);
            editingExercise = null;
        }
        finally
        {
            saving = false;
        }
    }

    async Task CancelExerciseEdit()
    {
        editingExercise = null;
        _expandedAlts.Clear();
        if (detail is not null)
            detail = await WorkoutService.GetCompletedWorkoutDtoAsync(detail.WorkoutId);
    }

    async Task DeleteWorkout()
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Workout",
            "Are you sure you wish to delete the workout?",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed != true) return;

        await WorkoutService.DeleteWorkoutAsync(Workout.WorkoutId);
        await OnDeleted.InvokeAsync();
    }
}
