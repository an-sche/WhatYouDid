@page "/Account/Manage"
@layout AccountLayout

@using Microsoft.AspNetCore.Identity
@using WhatYouDid.Data

@inject UserManager<ApplicationUser> UserManager
@inject IdentityUserAccessor UserAccessor

<PageTitle>Settings</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Settings</MudText>

<StatusMessage />

<div class="d-flex flex-column gap-3" style="max-width: 400px">
    @if (isLocalAccount)
    {
        <a href="Account/Manage/Email" style="text-decoration:none; color:inherit">
            <MudCard Style="cursor:pointer">
                <MudCardContent>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                        <MudIcon Icon="@Icons.Material.Filled.Email" Color="Color.Primary" />
                        <div>
                            <MudText Typo="Typo.subtitle1" Style="font-weight:bold">Change Email</MudText>
                            <MudText Typo="Typo.body2">Update the email address on your account.</MudText>
                        </div>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </a>

        <a href="Account/Manage/ChangePassword" style="text-decoration:none; color:inherit">
            <MudCard Style="cursor:pointer">
                <MudCardContent>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                        <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Primary" />
                        <div>
                            <MudText Typo="Typo.subtitle1" Style="font-weight:bold">Change Password</MudText>
                            <MudText Typo="Typo.body2">Update your account password.</MudText>
                        </div>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </a>
    }

    <a href="Account/Manage/DownloadWorkouts" style="text-decoration:none; color:inherit">
        <MudCard Style="cursor:pointer">
            <MudCardContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    <MudIcon Icon="@Icons.Material.Filled.FileDownload" Color="Color.Primary" />
                    <div>
                        <MudText Typo="Typo.subtitle1" Style="font-weight:bold">Download Workouts</MudText>
                        <MudText Typo="Typo.body2">Export your full workout history as a CSV file.</MudText>
                    </div>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </a>

    <a href="Account/Manage/DeletePersonalData" style="text-decoration:none; color:inherit">
        <MudCard Style="cursor:pointer">
            <MudCardContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    <MudIcon Icon="@Icons.Material.Filled.DeleteForever" Color="Color.Error" />
                    <div>
                        <MudText Typo="Typo.subtitle1" Style="font-weight:bold">Delete Account</MudText>
                        <MudText Typo="Typo.body2">Permanently delete your account and all your data.</MudText>
                    </div>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </a>
</div>

@code {
    private bool isLocalAccount;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        var user = await UserAccessor.GetRequiredUserAsync(HttpContext);
        isLocalAccount = await UserManager.HasPasswordAsync(user);
    }
}
