@page "/workouts"
@using WhatYouDid
@using Microsoft.AspNetCore.Authorization
@using WhatYouDid.Shared
@attribute [Authorize]
@rendermode InteractiveServer
@inject IWorkoutService WorkoutService
@inject DialogService DialogService

<PageTitle>Workout History</PageTitle>
<RadzenText TextStyle="TextStyle.H4">Workouts</RadzenText>

<RadzenTextBox Placeholder="Search workouts..." @bind-Value="searchText" @oninput="OnSearchInput" Style="width: 100%; margin-bottom: 12px;" />

@if (workouts is null)
{
    <RadzenCard Style="margin-bottom: 8px">
        <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
    </RadzenCard>
}
else
{
    foreach (var workout in workouts)
    {
        <WorkoutCard @key="workout.WorkoutId" Workout="@workout" OnDeleted="LoadPage" />
    }

    <RadzenPager @ref="pager" Count="totalWorkouts" PageSize="pageSize" PageNumbersCount="5" PageChanged="OnPageChanged" />
}

@code {

    RadzenPager? pager;
    List<Workout>? workouts;
    int totalWorkouts;
    const int pageSize = 10;
    string? searchText;
    CancellationTokenSource? _debounce;

    protected override async Task OnInitializedAsync()
    {
        await LoadPage();
    }

    private async Task LoadPage()
    {
        var currentPage = pager?.CurrentPage ?? 0;
        totalWorkouts = await WorkoutService.GetWorkoutsCountAsync(searchText);
        workouts = await WorkoutService.GetWorkoutsAsync(currentPage * pageSize, pageSize, searchText);
    }

    private async Task OnSearchInput(ChangeEventArgs args)
    {
        searchText = args.Value?.ToString();
        _debounce?.Cancel();
        _debounce = new CancellationTokenSource();
        var token = _debounce.Token;
        try
        {
            await Task.Delay(300, token);
            if (pager is not null) await pager.FirstPage();
            totalWorkouts = await WorkoutService.GetWorkoutsCountAsync(searchText);
            workouts = await WorkoutService.GetWorkoutsAsync(0, pageSize, searchText);
        }
        catch (TaskCanceledException) { }
    }

    private async Task OnPageChanged(PagerEventArgs args)
    {
        workouts = await WorkoutService.GetWorkoutsAsync(args.Skip, args.Top, searchText);
    }
}
