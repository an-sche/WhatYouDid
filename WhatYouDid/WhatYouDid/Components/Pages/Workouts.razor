@page "/workouts"
@using WhatYouDid
@using Microsoft.AspNetCore.Authorization
@using WhatYouDid.Shared
@attribute [Authorize]
@rendermode InteractiveServer
@inject IWhatYouDidApi Api
@inject DialogService DialogService

<PageTitle>Workout History</PageTitle>
<RadzenText TextStyle="TextStyle.H4">Workouts</RadzenText>

@if (workouts is null)
{
    <RadzenCard Style="margin-bottom: 8px">
        <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
    </RadzenCard>
}
else
{
    foreach (var workout in workouts)
    {
        <WorkoutCard Workout="@workout" OnDeleted="LoadPage" />
    }

    <RadzenPager @ref="pager" Count="totalWorkouts" PageSize="pageSize" PageNumbersCount="5" PageChanged="OnPageChanged" />
}

@code {

    RadzenPager? pager;
    List<Workout>? workouts;
    int totalWorkouts;
    const int pageSize = 10;

    protected override async Task OnInitializedAsync()
    {
        await LoadPage();
    }

    private async Task LoadPage()
    {
        var currentPage = pager?.CurrentPage ?? 0;
        totalWorkouts = await Api.GetWorkoutsCountAsync();
        workouts = await Api.GetWorkoutsAsync(currentPage * pageSize, pageSize);
    }

    private async Task OnPageChanged(PagerEventArgs args)
    {
        workouts = await Api.GetWorkoutsAsync(args.Skip, args.Top);
    }
}
