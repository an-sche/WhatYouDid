@page "/workouts"
@using WhatYouDid
@using Microsoft.AspNetCore.Authorization
@using WhatYouDid.Shared
@attribute [Authorize]
@rendermode InteractiveServer
@inject IWhatYouDidApi Api
@inject DialogService DialogService

<PageTitle>Workout History</PageTitle>
<RadzenText TextStyle="TextStyle.H4">Workouts</RadzenText>

<Virtualize ItemsProvider="LoadWorkouts" ItemSize="80" OverscanCount="3" @ref="virtualizeRef">
    <ItemContent>
        <WorkoutCard Workout="@context" OnDeleted="RefreshList" />
    </ItemContent>
    <Placeholder>
        <RadzenCard Style="margin-bottom: 8px">
            <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
        </RadzenCard>
    </Placeholder>
</Virtualize>

@code {

    Virtualize<Workout>? virtualizeRef;

    private async ValueTask<ItemsProviderResult<Workout>> LoadWorkouts(ItemsProviderRequest request)
    {
        var total = await Api.GetWorkoutsCountAsync();
        var items = await Api.GetWorkoutsAsync(request.StartIndex, request.Count);
        return new ItemsProviderResult<Workout>(items, total);
    }

    async Task RefreshList()
    {
        if (virtualizeRef is not null)
            await virtualizeRef.RefreshDataAsync();
    }
}
