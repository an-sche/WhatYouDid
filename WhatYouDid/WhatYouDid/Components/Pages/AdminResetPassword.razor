@page "/admin/resetpassword"
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using System.ComponentModel.DataAnnotations
@using WhatYouDid.Data
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]

@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager NavigationManager

<PageTitle>Reset Password</PageTitle>

<h1>Reset Password</h1>
<hr />

@if (users is null)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudTextField @bind-Value="searchText"
                  Immediate="true"
                  DebounceInterval="200"
                  Label="Search by email"
                  Variant="Variant.Outlined"
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  FullWidth="true"
                  Class="mb-3"
                  Clearable="true"
                  OnClearButtonClick="ClearSearch" />

    @if (!string.IsNullOrWhiteSpace(searchText))
    {
        var matches = FilteredUsers();
        if (!matches.Any())
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">No users match "@searchText".</MudText>
        }
        else
        {
            <MudList T="ApplicationUser" Class="mb-3" Dense="true">
                @foreach (var user in matches)
                {
                    <MudListItem T="ApplicationUser" OnClick="@(() => SelectUser(user))"
                                 Style="cursor:pointer"
                                 Class="@(selectedUser?.Id == user.Id ? "mud-selected-item" : "")">
                        <MudText Typo="Typo.body1">@user.Email</MudText>
                    </MudListItem>
                }
            </MudList>
        }
    }

    @if (selectedUser is not null)
    {
        <MudCard Class="mb-3">
            <MudCardContent>
                <MudText Typo="Typo.subtitle1" Style="font-weight:bold" Class="mb-2">@selectedUser.Email</MudText>
                <MudTextField @bind-Value="newPassword"
                              InputType="InputType.Password"
                              FullWidth="true"
                              Label="New password"
                              autocomplete="new-password"
                              Variant="Variant.Outlined" />
                <div class="mt-2">
                    <MudButton OnClick="ResetPasswordAsync"
                               StartIcon="@Icons.Material.Filled.LockReset"
                               Color="Color.Secondary"
                               Variant="Variant.Filled">Reset Password</MudButton>
                </div>
                @if (statusMessage is not null)
                {
                    <div class="small mt-1">@statusMessage</div>
                }
            </MudCardContent>
        </MudCard>
    }
}

<div class="mt-3">
    <MudButton OnClick="@(() => NavigationManager.NavigateTo("/admin"))" Variant="Variant.Outlined">Back</MudButton>
</div>

@code {
    private List<ApplicationUser>? users;
    private string searchText = string.Empty;
    private ApplicationUser? selectedUser;
    private string? newPassword;
    private string? statusMessage;

    protected override async Task OnInitializedAsync()
    {
        users = await UserManager.Users.OrderBy(u => u.Email).ToListAsync();
    }

    private IEnumerable<ApplicationUser> FilteredUsers()
    {
        if (users is null || string.IsNullOrWhiteSpace(searchText))
            return [];

        return users
            .Where(u => u.Email?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true)
            .Take(20);
    }

    private void SelectUser(ApplicationUser user)
    {
        selectedUser = user;
        newPassword = null;
        statusMessage = null;
    }

    private void ClearSearch()
    {
        searchText = string.Empty;
        selectedUser = null;
        newPassword = null;
        statusMessage = null;
    }

    private async Task ResetPasswordAsync()
    {
        statusMessage = null;

        if (selectedUser is null)
            return;

        if (string.IsNullOrWhiteSpace(newPassword))
        {
            statusMessage = "Password is required.";
            return;
        }

        var token = await UserManager.GeneratePasswordResetTokenAsync(selectedUser);
        var result = await UserManager.ResetPasswordAsync(selectedUser, token, newPassword);
        if (result.Succeeded)
        {
            statusMessage = "Password reset.";
            newPassword = string.Empty;
        }
        else
        {
            statusMessage = "Error: " + string.Join(", ", result.Errors.Select(e => e.Description));
        }
    }
}
