@page "/admin/resetpassword"
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using System.ComponentModel.DataAnnotations
@using WhatYouDid.Data
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]

@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager NavigationManager

<PageTitle>Reset Password</PageTitle>

<h1>Reset Password</h1>
<hr />

@if (users is null)
{
    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
}
else
{
    @foreach (var user in users)
    {
        var model = resetModels.GetOrAdd(user.Id, _ => new ResetModel());
        <RadzenCard style="margin-bottom: 8px">
            <RadzenText TextStyle="TextStyle.Subtitle1" Style="font-weight:bold">@user.Email</RadzenText>
            <RadzenTextBox @bind-Value="model.NewPassword" Type="Password" Style="width:100%" Placeholder="New password" AutoCompleteType="AutoCompleteType.NewPassword" />
            <div class="mt-2">
                <RadzenButton Click="@(async () => await ResetPasswordAsync(user, model))" Icon="lock_reset" ButtonStyle="ButtonStyle.Secondary">Reset Password</RadzenButton>
            </div>
            @if (resetStatus.TryGetValue(user.Id, out var msg) && msg is not null)
            {
                <div class="small mt-1">@msg</div>
            }
        </RadzenCard>
    }
}

<div class="mt-3">
    <RadzenButton ButtonStyle="ButtonStyle.Light" Click="@(() => NavigationManager.NavigateTo("/admin"))">Back</RadzenButton>
</div>

@code {
    private List<ApplicationUser>? users;
    private Dictionary<string, string?> resetStatus = new();
    private System.Collections.Concurrent.ConcurrentDictionary<string, ResetModel> resetModels = new();

    protected override async Task OnInitializedAsync()
    {
        users = await UserManager.Users.ToListAsync();
    }

    private async Task ResetPasswordAsync(ApplicationUser user, ResetModel model)
    {
        resetStatus[user.Id] = null;

        if (string.IsNullOrWhiteSpace(model.NewPassword))
        {
            resetStatus[user.Id] = "Password is required.";
            return;
        }

        var token = await UserManager.GeneratePasswordResetTokenAsync(user);
        var result = await UserManager.ResetPasswordAsync(user, token, model.NewPassword);
        if (result.Succeeded)
        {
            resetStatus[user.Id] = "Password reset.";
            model.NewPassword = string.Empty;
        }
        else
        {
            resetStatus[user.Id] = "Error: " + string.Join(", ", result.Errors.Select(e => e.Description));
        }
        StateHasChanged();
    }

    private sealed class ResetModel
    {
        [Required]
        public string? NewPassword { get; set; }
    }
}
