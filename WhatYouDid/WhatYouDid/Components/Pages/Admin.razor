@page "/admin"
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Admin</PageTitle>

<h1>Administration</h1>
<hr />

<div class="d-flex flex-column gap-3" style="max-width: 400px">
    <a href="/admin/createuser" style="text-decoration:none; color:inherit">
        <MudCard Style="cursor:pointer">
            <MudCardContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Color="Color.Primary" />
                    <div>
                        <MudText Typo="Typo.subtitle1" Style="font-weight:bold">Create User</MudText>
                        <MudText Typo="Typo.body2">Add a new user account.</MudText>
                    </div>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </a>

    <a href="/admin/resetpassword" style="text-decoration:none; color:inherit">
        <MudCard Style="cursor:pointer">
            <MudCardContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    <MudIcon Icon="@Icons.Material.Filled.LockReset" Color="Color.Primary" />
                    <div>
                        <MudText Typo="Typo.subtitle1" Style="font-weight:bold">Reset Password</MudText>
                        <MudText Typo="Typo.body2">Reset a password for an existing user.</MudText>
                    </div>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </a>

    <a href="https://resend.com/overview" target="_blank" style="text-decoration:none; color:inherit">
        <MudCard Style="cursor:pointer">
            <MudCardContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    <MudIcon Icon="@Icons.Material.Filled.Email" Color="Color.Primary" />
                    <div>
                        <MudText Typo="Typo.subtitle1" Style="font-weight:bold">Resend (Email) Usage Statistics</MudText>
                        <MudText Typo="Typo.body2">Free tier: 3,000 emails/month, 100/day. Click to view live stats on resend.com.</MudText>
                    </div>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </a>
</div>
