@page "/admin"
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Admin</PageTitle>

<h1>Administration</h1>
<hr />

<div class="d-flex flex-column gap-3" style="max-width: 400px">
    <RadzenCard>
        <RadzenText TextStyle="TextStyle.Subtitle1" Style="font-weight:bold">Create User</RadzenText>
        <RadzenText TextStyle="TextStyle.Body2">Add a new user account.</RadzenText>
        <div class="mt-2">
            <a href="/admin/createuser" class="rz-button rz-button-md rz-variant-filled rz-primary">Create User</a>
        </div>
    </RadzenCard>

    <RadzenCard>
        <RadzenText TextStyle="TextStyle.Subtitle1" Style="font-weight:bold">Reset Password</RadzenText>
        <RadzenText TextStyle="TextStyle.Body2">Reset a password for an existing user.</RadzenText>
        <div class="mt-2">
            <a href="/admin/resetpassword" class="rz-button rz-button-md rz-variant-filled rz-secondary">Reset Password</a>
        </div>
    </RadzenCard>
</div>

