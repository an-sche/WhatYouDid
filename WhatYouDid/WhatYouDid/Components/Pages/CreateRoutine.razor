@page "/createroutine"

@using Microsoft.AspNetCore.Authorization
@using WhatYouDid.Shared
@attribute [Authorize]
@rendermode InteractiveServer
@inject IWhatYouDidApi Api
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IBrowserStorage BrowserStorage


<PageTitle>Create Routine</PageTitle>
<RadzenText TextStyle="TextStyle.H4">Create Routine</RadzenText>

<div style="width: 560px; max-width: 100%">
		<hr />
		<EditForm Model=@routine OnValidSubmit="OnValidSubmit" OnInvalidSubmit="OnInvalidSubmit" FormName="EditRoutine" Context="EditRoutine">

			<DataAnnotationsValidator />
			<ValidationSummary />

			<RadzenFormField AllowFloatingLabel="false" Text="Routine Name" Style="width: 100%">
				<ChildContent>
					<RadzenTextBox Name="RoutineName" @bind-Value=routine.Name />
				</ChildContent>
			</RadzenFormField>
			<ValidationMessage For="() => routine.Name" />
			<hr />

			@for (int idx = 0; idx < routine.Exercises.Count; idx++)
			{
				var e = routine.Exercises[idx];
				var i = idx;

				<RadzenCard Variant="Variant.Outlined" class="rz-mb-4" data-exercise-card="@_exerciseKeys[i]">
					<RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" class="rz-mb-2">
						<RadzenText TextStyle="TextStyle.Subtitle2">@e.Sequence.</RadzenText>
						<RadzenStack Orientation="Orientation.Horizontal" Gap="4px">
							<RadzenButton Click=@(() => MoveExerciseUp(e)) Icon="arrow_upward" Variant="Variant.Outlined" ButtonStyle="ButtonStyle.Dark" Size="ButtonSize.Medium" Disabled="@(i == 0)" />
							<RadzenButton Click=@(() => MoveExerciseDown(e)) Icon="arrow_downward" Variant="Variant.Outlined" ButtonStyle="ButtonStyle.Dark" Size="ButtonSize.Medium" Disabled="@(i == routine.Exercises.Count - 1)" />
							<RadzenButton Click=@(() => RemoveExercise(e)) Icon="delete" Variant="Variant.Outlined" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Medium" />
						</RadzenStack>
					</RadzenStack>
					<RadzenFormField AllowFloatingLabel="false" Text="Exercise Name" Style="width: 100%" class="rz-mb-2">
						<ChildContent>
							<RadzenTextBox Name="@($"ExerciseName_{i}")" @bind-Value=e.Name />
						</ChildContent>
					</RadzenFormField>
					<ValidationMessage For="() => e.Name" />

					<RadzenFormField AllowFloatingLabel="false" Text="Description (optional)" Style="width: 100%" class="rz-mt-3">
						<ChildContent>
							<RadzenTextArea Name="@($"Description_{i}")" @bind-Value=e.Description Rows="2" Style="width: 100%" />
						</ChildContent>
					</RadzenFormField>
					<ValidationMessage For="() => e.Description" />

					<RadzenFormField AllowFloatingLabel="false" Text="Sets" class="rz-mt-3">
						<ChildContent>
							<RadzenNumeric Name="@($"Sets_{i}")" @bind-Value=e.Sets Min="1" Max="10" />
						</ChildContent>
					</RadzenFormField>
					<ValidationMessage For="() => e.Sets" />

					<RadzenStack Orientation="Orientation.Horizontal" Gap="1.5rem" Wrap="FlexWrap.Wrap" class="rz-mt-3">
						<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
							<RadzenCheckBox Name="@($"HasReps_{i}")" @bind-Value=e.HasReps />
							<RadzenLabel Text="Reps" Component="@($"HasReps_{i}")" />
						</RadzenStack>
						<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
							<RadzenCheckBox Name="@($"HasWeight_{i}")" @bind-Value=e.HasWeight />
							<RadzenLabel Text="Weight" Component="@($"HasWeight_{i}")" />
						</RadzenStack>
						<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
							<RadzenCheckBox Name="@($"HasDuration_{i}")" @bind-Value=e.HasDuration />
							<RadzenLabel Text="Duration" Component="@($"HasDuration_{i}")" />
						</RadzenStack>
					</RadzenStack>
				</RadzenCard>
			}

			<RadzenButton Click="@AddExercise" Text="Add Exercise" Icon="add_circle_outline" ButtonStyle="ButtonStyle.Primary" class="rz-mb-4" Style="width: 100%" />

			@if (errorMessage is not null)
			{
				<RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat" class="rz-mb-3">
					@errorMessage
				</RadzenAlert>
			}

			<RadzenButton ButtonType="ButtonType.Submit" Text="Create Routine" Icon="save" ButtonStyle="ButtonStyle.Secondary" IsBusy="@Busy" Style="width: 100%" />

		</EditForm>
	</div>



@code {

	private const string DraftKey = "CreateRoutine_Draft";
	private bool _initialized = false;
	private bool Busy = false;
	private string? errorMessage = null;
	private List<string> _exerciseKeys = [Guid.NewGuid().ToString("N")];
	private Dictionary<string, double>? _flipPositions;

	[Parameter]
	public int? Id { get; set; }

	CreateRoutineDto routine = new() {
		Name = string.Empty,
		Exercises = new List<CreateExerciseDto>()
		{
			new CreateExerciseDto()
			{
				Sequence = 1,
				Name = string.Empty,
				Sets = 1,

				HasReps = true,
				HasWeight = true
			}
		},
	};

	async Task OnInvalidSubmit()
	{
		await Task.Yield();
	}

	async Task OnValidSubmit()
	{
		if (Busy) return;
		Busy = true;
		errorMessage = null;

		try
		{
			if (routine.Exercises.Any(e => string.IsNullOrWhiteSpace(e.Name) || e.Name.Trim().Length < 3))
			{
				errorMessage = "All exercises must have a name (at least 3 characters).";
				return;
			}

			var success = await Api.AddRoutineAsync(routine);
			if (!success)
			{
				errorMessage = "Failed to create routine. Please try again.";
				return;
			}

			await BrowserStorage.DeleteAsync(DraftKey);
			Navigation.NavigateTo("routines");
		}
		catch
		{
			errorMessage = "An unexpected error occurred. Please try again.";
		}
		finally
		{
			Busy = false;
		}
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (_flipPositions is not null)
		{
			await JS.InvokeVoidAsync("exerciseCardHelper.animateFlip", _flipPositions);
			_flipPositions = null;
		}

		if (firstRender)
		{
			var draft = await BrowserStorage.GetAsync<CreateRoutineDto>(DraftKey);
			if (draft is not null)
			{
				routine = draft;
				_exerciseKeys = routine.Exercises.Select(_ => Guid.NewGuid().ToString("N")).ToList();
				StateHasChanged();
			}
			_initialized = true;
			return;
		}

		if (_initialized)
		{
			await BrowserStorage.SetAsync(DraftKey, routine);
		}
	}

	void AddExercise()
	{
		routine.Exercises.Add(
			new CreateExerciseDto()
			{
				Sequence = routine.Exercises.Count + 1,
				Name = string.Empty,
				Sets = 1,

				HasReps = true,
				HasWeight = true
			}
		);
		_exerciseKeys.Add(Guid.NewGuid().ToString("N"));
	}

	void RemoveExercise(CreateExerciseDto e)
	{
		int index = routine.Exercises.IndexOf(e);
		if (routine.Exercises.Remove(e))
		{
			_exerciseKeys.RemoveAt(index);
			RenumberExercises();
		}
	}

	async Task MoveExerciseUp(CreateExerciseDto e)
	{
		int index = routine.Exercises.IndexOf(e);
		if (index <= 0) return;
		_flipPositions = await JS.InvokeAsync<Dictionary<string, double>>("exerciseCardHelper.capturePositions");
		routine.Exercises.RemoveAt(index);
		routine.Exercises.Insert(index - 1, e);
		(_exerciseKeys[index], _exerciseKeys[index - 1]) = (_exerciseKeys[index - 1], _exerciseKeys[index]);
		RenumberExercises();
	}

	async Task MoveExerciseDown(CreateExerciseDto e)
	{
		int index = routine.Exercises.IndexOf(e);
		if (index < 0 || index >= routine.Exercises.Count - 1) return;
		_flipPositions = await JS.InvokeAsync<Dictionary<string, double>>("exerciseCardHelper.capturePositions");
		routine.Exercises.RemoveAt(index);
		routine.Exercises.Insert(index + 1, e);
		(_exerciseKeys[index], _exerciseKeys[index + 1]) = (_exerciseKeys[index + 1], _exerciseKeys[index]);
		RenumberExercises();
	}

	void RenumberExercises()
	{
		for (int i = 0; i < routine.Exercises.Count; i++)
			routine.Exercises[i].Sequence = i + 1;
	}

}
