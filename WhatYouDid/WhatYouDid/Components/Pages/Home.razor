@page "/"
@inject NavigationManager NavigationManager

<PageTitle>Home</PageTitle>

<AuthorizeView>
	<Authorized>
		<MudGrid Class="mb-6">
			<MudItem xs="12">
				<a href="/routines" class="home-nav-card home-nav-card--primary">
					<MudIcon Icon="@Icons.Material.Filled.PlaylistPlay" />
					<span>Start Workout</span>
					<small>Browse routines</small>
				</a>
			</MudItem>
			<MudItem xs="6" md="4">
				<a href="/createroutine" class="home-nav-card">
					<MudIcon Icon="@Icons.Material.Filled.AddCircle" Style="color: var(--mud-palette-success)" />
					<span>Create Routine</span>
				</a>
			</MudItem>
			<MudItem xs="6" md="4">
				<a href="/workouts" class="home-nav-card">
					<MudIcon Icon="@Icons.Material.Filled.FitnessCenter" Style="color: var(--mud-palette-primary)" />
					<span>Workouts</span>
				</a>
			</MudItem>
			<MudItem xs="6" md="4">
				<a href="/progress" class="home-nav-card">
					<MudIcon Icon="@Icons.Material.Filled.TrendingUp" Style="color: var(--mud-palette-success)" />
					<span>Progress</span>
				</a>
			</MudItem>
			<MudItem xs="6" md="4">
				<a href="/dashboard" class="home-nav-card">
					<MudIcon Icon="@Icons.Material.Filled.BarChart" Style="color: var(--mud-palette-info)" />
					<span>Stats</span>
				</a>
			</MudItem>
			<MudItem xs="6" md="4">
				<a href="/Account/Manage" class="home-nav-card">
					<MudIcon Icon="@Icons.Material.Filled.ManageAccounts" Style="color: var(--mud-palette-warning)" />
					<span>Account</span>
				</a>
			</MudItem>
			<MudItem xs="6" md="4">
				<form action="Account/Logout" method="post" class="home-nav-card-form">
					<AntiforgeryToken />
					<input type="hidden" name="ReturnUrl" value="" />
					<button type="submit" class="home-nav-card">
						<MudIcon Icon="@Icons.Material.Filled.Logout" Style="color: var(--mud-palette-secondary)" />
						<span>Logout</span>
					</button>
				</form>
			</MudItem>
			<AuthorizeView Roles="Admin">
				<Authorized Context="adminContext">
					<MudItem xs="6" md="4">
						<a href="/admin" class="home-nav-card">
							<MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Style="color: var(--mud-palette-error)" />
							<span>Admin</span>
						</a>
					</MudItem>
				</Authorized>
			</AuthorizeView>
		</MudGrid>
	</Authorized>
	<NotAuthorized>
		<MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Row="true" Class="mt-6" Spacing="4">
			<a href="/Account/Login" class="home-nav-card home-nav-card--login">
				<MudIcon Icon="@Icons.Material.Filled.Login" Style="color: var(--mud-palette-primary)" />
				<span>Log In</span>
			</a>
			<a href="/Account/Register" class="home-nav-card home-nav-card--login">
				<MudIcon Icon="@Icons.Material.Filled.PersonAdd" Style="color: var(--mud-palette-success)" />
				<span>Create Account</span>
			</a>
		</MudStack>
	</NotAuthorized>
</AuthorizeView>

<style>
	.home-nav-card-form {
		width: 100%;
		margin: 0;
		padding: 0;
	}

	.home-nav-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		padding: 1.5rem 1rem;
		width: 100%;
		border-radius: var(--mud-default-borderradius);
		border: 1px solid var(--mud-palette-divider);
		background: var(--mud-palette-background);
		color: var(--mud-palette-text-primary);
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 500;
		cursor: pointer;
		transition: background 0.15s, border-color 0.15s, box-shadow 0.15s;
		box-shadow: var(--mud-elevation-1);
	}

	.home-nav-card small {
		font-size: 0.75rem;
		font-weight: 400;
		opacity: 0.7;
	}

	.home-nav-card .mud-icon-root {
		font-size: 2rem;
	}

	.home-nav-card:hover {
		background: rgba(57, 255, 20, 0.08);
		border-color: var(--mud-palette-primary);
		box-shadow: var(--mud-elevation-2);
		color: var(--mud-palette-text-primary);
	}

	/* Login card — centered, fixed width */
	.home-nav-card--login {
		width: 200px;
	}

	/* Start Workout — primary hero card */
	.home-nav-card--primary {
		background: var(--mud-palette-primary);
		border-color: var(--mud-palette-primary-darken);
		color: var(--mud-palette-primary-text);
		box-shadow: var(--mud-elevation-3);
		font-size: 1.1rem;
	}

	.home-nav-card--primary .mud-icon-root {
		font-size: 2.5rem;
		color: var(--mud-palette-primary-text);
	}

	.home-nav-card--primary small {
		opacity: 0.85;
	}

	.home-nav-card--primary:hover {
		background: var(--mud-palette-primary-darken);
		border-color: var(--mud-palette-primary-darken);
		color: var(--mud-palette-primary-text);
		box-shadow: var(--mud-elevation-4);
	}
</style>
