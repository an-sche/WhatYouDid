@page "/dashboard"
@using WhatYouDid.Shared
@using System.Net.Http.Json
@attribute [Authorize]
@rendermode InteractiveServer

@inject IDashboardService Service
@inject HttpClient Http

<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<PageTitle>Dashboard</PageTitle>

<h1>Dashboard</h1>

<MudSelect T="int" Value="selectedYear" ValueChanged="ReloadDataAsync" Style="min-width:160px" Variant="Variant.Outlined">
    @foreach (var item in yearItems)
    {
        <MudSelectItem Value="@item.Value">@item.Label</MudSelectItem>
    }
</MudSelect>
<br />

@if (dashboard is null)
{
    <MudProgressLinear Indeterminate="true" />
    return;
}
@if (dashboard.TopWorkouts is null || !dashboard.TopWorkouts.Any())
{
    <MudItem xs="12">
        <MudCard>
            <MudCardContent>
                <div>No workout data for the selected year(s)</div>
            </MudCardContent>
        </MudCard>
    </MudItem>
    return;
}

<MudGrid Class="mb-6">
    @foreach (var w in dashboard.TopWorkouts)
    {
        <MudItem xs="12" sm="6" md="4">
            <MudCard Style="height:150px">
                <MudCardContent>
                    <h5>@w.RoutineName</h5>
                    <div class="display-6">@w.Count</div>
                    <div class="text-muted">times performed</div>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }

    <MudItem xs="12" sm="6" md="4">
        <MudCard Style="height:150px">
            <MudCardContent>
                <h6>Total Workout Duration</h6>
                <div class="display-6">@FormatMinutes(dashboard.TotalWorkoutDuration)</div>
                <div class="text-muted">sum of all workouts</div>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="4">
        <MudCard Style="height:150px">
            <MudCardContent>
                <h6>Total Reps Completed</h6>
                <div class="display-6">@dashboard.TotalReps</div>
                <div class="text-muted">count of reps</div>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="4">
        <MudCard Style="height:150px">
            <MudCardContent>
                <h6>Total Workouts</h6>
                <div class="display-6">@dashboard.TotalWorkouts</div>
                <div class="text-muted">workouts completed</div>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private record YearItem(int Value, string Label);

    private DashboardDto? dashboard;
    private int selectedYear; // 0 = All Years
    private List<YearItem> yearItems = [];

    private static string FormatMinutes(int? minutes)
    {
        if (!minutes.HasValue)
            return "-";

        var ts = TimeSpan.FromMinutes(minutes.Value);
        if (ts.TotalHours >= 1)
        {
            return $"{(int)ts.TotalHours}h {ts.Minutes}m";
        }
        return $"{ts.Minutes}m";
    }

    protected override async Task OnInitializedAsync()
    {
        var years = await Service.GetActiveYearsAsync();
        yearItems = [new YearItem(0, "All Years"), ..years.Select(y => new YearItem(y, y.ToString()))];
        await ReloadDataAsync(selectedYear);
    }

    private async Task ReloadDataAsync(int year)
    {
        selectedYear = year;
        try
        {
            dashboard = await Service.GetDashboardForUserAsync(selectedYear == 0 ? null : selectedYear);
        }
        catch
        {
            dashboard = new DashboardDto { TopWorkouts = new List<WorkoutSummaryDto>() };
        }
        StateHasChanged();
    }
}
