@page "/dashboard"
@using WhatYouDid.Shared
@using System.Net.Http.Json
@attribute [Authorize]
@rendermode InteractiveServer

@inject IDashboardService Service
@inject HttpClient Http

<PageTitle>Dashboard</PageTitle>

<h1>Dashboard</h1>

<RadzenStack Orientation="Orientation.Horizontal" Wrap="FlexWrap.Wrap" Gap="8px">
    <RadzenNumeric Style="flex:1; min-width:160px" Step="1" Min="1900" Max="DateTime.Now.Year" Placeholder="Enter Year" @bind-Value="selectedYear" @bind-Value:after="ReloadDataAsync"/>
    <RadzenButton Click="@ClearYear" Icon="delete" ButtonStyle="ButtonStyle.Secondary">Clear</RadzenButton>
</RadzenStack>
<br />

@if (dashboard is null)
{
    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
    return;
}
@if (dashboard.TopWorkouts is null || !dashboard.TopWorkouts.Any())
{
    <RadzenColumn Size="12">
        <RadzenCard>
            <ChildContent>
                <div>No workout data for the selected year(s)</div>
            </ChildContent>
        </RadzenCard>
    </RadzenColumn>
    return;
}

<RadzenRow Gap="1rem" RowGap="1rem" class="rz-mt-2 rz-mb-6">
    @foreach (var w in dashboard.TopWorkouts)
    {
        <RadzenColumn Size="12" SizeSM="6" SizeMD="4">
            <RadzenCard Style="height:150px">
                <ChildContent>
                    <h5>@w.RoutineName</h5>
                    <div class="display-6">@w.Count</div>
                    <div class="text-muted">times performed</div>
                </ChildContent>
            </RadzenCard>
        </RadzenColumn>
    }

    <RadzenColumn Size="12" SizeSM="6" SizeMD="4">
        <RadzenCard Style="height:150px">
            <ChildContent>
                <h6>Total Workout Duration</h6>
                <div class="display-6">@FormatMinutes(dashboard.TotalWorkoutDuration)</div>
                <div class="text-muted">sum of all workouts</div>
            </ChildContent>
        </RadzenCard>
    </RadzenColumn>

    <RadzenColumn Size="12" SizeSM="6" SizeMD="4">
        <RadzenCard Style="height:150px">
            <ChildContent>
                <h6>Total Reps Completed</h6>
                <div class="display-6">@dashboard.TotalReps</div>
                <div class="text-muted">count of reps</div>
            </ChildContent>
        </RadzenCard>
    </RadzenColumn>

    <RadzenColumn Size="12" SizeSM="6" SizeMD="4">
        <RadzenCard Style="height:150px">
            <ChildContent>
                <h6>Total Workouts</h6>
                <div class="display-6">@dashboard.TotalWorkouts</div>
                <div class="text-muted">workouts completed</div>
            </ChildContent>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>

@code {
    private DashboardDto? dashboard;
    private int? selectedYear;

    private static string FormatMinutes(int? minutes)
    {
        if (!minutes.HasValue)
            return "-";

        var ts = TimeSpan.FromMinutes(minutes.Value);
        if (ts.TotalHours >= 1)
        {
            return $"{(int)ts.TotalHours}h {ts.Minutes}m";
        }
        return $"{ts.Minutes}m";
    }

    protected override async Task OnInitializedAsync()
    {
        await ReloadDataAsync();
    }

    private async Task ClearYear()
    {
        selectedYear = null;
        await ReloadDataAsync();
    }

    private async Task ReloadDataAsync()
    {
        try
        {
            dashboard = await Service.GetDashboardForUserAsync(selectedYear);
        }
        catch
        {
            dashboard = new DashboardDto { TopWorkouts = new List<WorkoutSummaryDto>() };
        }
        StateHasChanged();
    }
}
