@page "/dashboard"
@using WhatYouDid.Shared
@using System.Net.Http.Json
@rendermode InteractiveServer

@inject IDashboardService Service
@inject HttpClient Http

<PageTitle>Dashboard</PageTitle>

<h1>Dashboard</h1>

<RadzenStack Orientation="Orientation.Horizontal"> 
    <RadzenNumeric Style="width:240px" Step="1" Min="1900" Max="DateTime.Now.Year" Placeholder="Enter Year" @bind-Value="selectedYear" @bind-Value:after="ReloadDataAsync"/>
    <RadzenButton Style="width:150px" Click="@ClearYear" Icon="delete" ButtonStyle="ButtonStyle.Secondary">Clear</RadzenButton>
</RadzenStack>
<br />

@if (dashboard is null)
{
    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
    return;
}
@if (dashboard.TopWorkouts is null || !dashboard.TopWorkouts.Any())
{
    <RadzenColumn Size="12">
        <RadzenCard>
            <ChildContent>
                <div>No workout data for the selected year(s)</div>
            </ChildContent>
        </RadzenCard>
    </RadzenColumn>
    return;
}

<RadzenStack Style="max-width: 900px" Orientation="Orientation.Horizontal" Gap="16px" AlignItems="AlignItems.Start" Wrap="FlexWrap.Wrap">
        @foreach (var w in dashboard.TopWorkouts)
        {
                <RadzenCard Style="height:150px; width:280px">
                    <ChildContent>
                        <h5>@w.RoutineName</h5>
                        <div class="display-6">@w.Count</div>
                        <div class="text-muted">times performed</div>
                    </ChildContent>
                </RadzenCard>
        }

            <RadzenCard Style="height:150px; width:280px">
                <ChildContent>
                    <h6>Total Workout Duration</h6>
                    <div class="display-6">@FormatMinutes(dashboard.TotalWorkoutDuration)</div>
                    <div class="text-muted">sum of all workouts</div>
                </ChildContent>
            </RadzenCard>

            <RadzenCard Style="height:150px; width:280px">
                <ChildContent>
                    <h6>Total Reps Completed</h6>
                    <div class="display-6">@dashboard.TotalReps</div>
                    <div class="text-muted">count of reps</div>
                </ChildContent>
            </RadzenCard>

            <RadzenCard Style="height:150px; width:280px">
                <ChildContent>
                    <h6>Longest Workout</h6>
                    @if (dashboard.LongestWorkoutRoutineName is not null && dashboard.LongestWorkoutDuration.HasValue)
                    {
                        <div class="fw-bold">@dashboard.LongestWorkoutRoutineName</div>
                        <div>@(dashboard.LongestWorkoutDate?.ToString("yyyy-MM-dd")) — @FormatMinutes(dashboard.LongestWorkoutDuration)</div>
                    }
                    else
                    {
                        <div class="text-muted">No completed workouts</div>
                    }
                </ChildContent>
            </RadzenCard>
</RadzenStack>

@code {
    private DashboardDto? dashboard;
    private int? selectedYear;

    private static string FormatMinutes(int? minutes)
    {
        if (!minutes.HasValue)
            return "-";

        var ts = TimeSpan.FromMinutes(minutes.Value);
        if (ts.TotalHours >= 1)
        {
            return $"{(int)ts.TotalHours}h {ts.Minutes}m";
        }
        return $"{ts.Minutes}m";
    }

    protected override async Task OnInitializedAsync()
    {
        await ReloadDataAsync();
    }

    private async Task ClearYear()
    {
        selectedYear = null;
        await ReloadDataAsync();
    }

    private async Task ReloadDataAsync()
    {
        try
        {
            dashboard = await Service.GetDashboardForUserAsync(selectedYear);
        }
        catch
        {
            dashboard = new DashboardDto { TopWorkouts = new List<WorkoutSummaryDto>() };
        }
        StateHasChanged();
    }
}
