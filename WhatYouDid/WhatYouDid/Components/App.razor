<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<base href="/" />
    <link rel="stylesheet" href="bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="WhatYouDid.styles.css" />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&family=Press+Start+2P&display=swap" rel="stylesheet" />
    <link href="@Assets["_content/MudBlazor/MudBlazor.min.css"]" rel="stylesheet" />
    <link href="_content/CodeBeam.MudBlazor.Extensions/MudExtensions.min.css" rel="stylesheet" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <link rel="manifest" href="manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/icon192x192.png" />
    <meta name="theme-color" content="#0D0D0D" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <div id="sw-update-banner" style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:9999;background:#0D0D0D;color:#F0F0F0;border-top:2px solid #39FF14;padding:12px 16px;align-items:center;justify-content:space-between;gap:12px;">
        <span>A new version is available.</span>
        <button onclick="window.location.reload()" style="background:#39FF14;color:#000;border:none;padding:6px 16px;border-radius:4px;cursor:pointer;font-weight:600;">Reload</button>
    </div>
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/service-worker.js');
            navigator.serviceWorker.addEventListener('message', event => {
                if (event.data?.type === 'SW_UPDATED') {
                    document.getElementById('sw-update-banner').style.display = 'flex';
                }
            });
        }
    </script>
    <script src="cardswapper.js"></script>
    <script src="wakelock.js"></script>
	<script src="_framework/blazor.web.js"></script>
    <script src="@Assets["_content/MudBlazor/MudBlazor.min.js"]"></script>
    <script src="_content/CodeBeam.MudBlazor.Extensions/MudExtensions.min.js"></script>
</body>

</html>