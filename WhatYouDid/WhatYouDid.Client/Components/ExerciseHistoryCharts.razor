@using WhatYouDid.Shared
@using MudBlazor.Charts

@if (_maxSets > 1)
{
    <MudChipSet T="int" SelectedValue="_selectedSet" SelectedValueChanged="OnSetChanged" SelectedColor="Color.Primary" Class="mb-2 d-flex justify-center">
        @for (int i = 1; i <= _maxSets; i++)
        {
            int index = i;
            <MudChip T="int" Value="@index" Size="Size.Medium" Variant="Variant.Outlined">Set @index</MudChip>
        }
    </MudChipSet>
}

<MudCard>
    <MudCardContent>
        @if (_series.Count > 0)
        {
            <Line T="double"
                  ChartSeries="_series"
                  ChartLabels="_xLabels"
                  ChartOptions="_chartOptions"
                  Width="100%" Height="300px" />
        }
    </MudCardContent>
</MudCard>

@code {
    [Parameter, EditorRequired] public ExerciseHistoryDto History { get; set; } = default!;

    int _selectedSet = 1;
    int _maxSets;
    string[] _xLabels = [];
    List<ChartSeries<double>> _series = [];

    readonly LineChartOptions _chartOptions = new()
    {
        LineStrokeWidth = 6,
        YAxisTicks = 5,
        MaxNumYAxisTicks = 5,
        ShowDataMarkers = true,
        XAxisLabelRotation = 60,
        YAxisFormat = "0",
        InterpolationOption = InterpolationOption.EndSlope
    };

    protected override void OnParametersSet()
    {
        _selectedSet = 1;
        _maxSets = Math.Min(History.Sessions.Max(s => s.Sets.Count), 6);
        _xLabels = ThinLabels(
            History.Sessions.Select(s => s.Date.LocalDateTime.ToString("MMM d")).ToArray());

        BuildSeries();
    }

    private void OnSetChanged(int setNumber)
    {
        _selectedSet = setNumber;
        BuildSeries();
    }

    private void BuildSeries()
    {
        _series = [];

        if (History.HasReps)
        {
            var data = GetSetData(s => (double?)s.Reps);
            if (data.Any(v => !double.IsNaN(v)))
                _series.Add(new ChartSeries<double> { Name = "Reps", Data = data });
        }

        if (History.HasWeight)
        {
            var data = GetSetData(s => (double?)s.Weight);
            if (data.Any(v => !double.IsNaN(v)))
                _series.Add(new ChartSeries<double> { Name = "Weight", Data = data });
        }

        if (History.HasDuration)
        {
            var data = GetSetData(s => (double?)s.Duration);
            if (data.Any(v => !double.IsNaN(v)))
                _series.Add(new ChartSeries<double> { Name = "Duration (sec)", Data = data });
        }
    }

    // Show at most 6 labels. Always keep first and last; blank everything in between
    // that doesn't fall on a calculated step.
    private static string[] ThinLabels(string[] labels)
    {
        const int maxLabels = 10;
        if (labels.Length <= maxLabels) return labels;

        var result = new string[labels.Length];
        double step = (double)(labels.Length - 1) / (maxLabels - 1);

        for (int i = 0; i < labels.Length; i++)
            result[i] = string.Empty;

        for (int i = 0; i < maxLabels; i++)
        {
            int index = (int)Math.Round(i * step);
            result[index] = labels[index];
        }

        return result;
    }

    private double[] GetSetData(Func<ExerciseSetHistoryDto, double?> getValue) =>
        History.Sessions.Select(session =>
        {
            var set = session.Sets.FirstOrDefault(s => s.SetNumber == _selectedSet);
            if (set is null) return double.NaN;
            return getValue(set) ?? double.NaN;
        }).ToArray();
}
