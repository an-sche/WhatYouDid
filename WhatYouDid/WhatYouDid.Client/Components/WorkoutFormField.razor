@using Microsoft.AspNetCore.Authorization
@using System.Text

@inject IDialogService DialogService

<MudTextFieldExtended T="int?" Label="@InternalTitle"
    Value="@EnterValue" ValueChanged="@OnChange"
    Style="width: 100%" Variant="Variant.Outlined"
    InputMode="InputMode.numeric">
    <AdornmentStart>
        <MudIcon Icon="@Icon" Size="Size.Small" Class="mr-1" />
    </AdornmentStart>
    <AdornmentEnd>
        @if (Goal is not null)
        {
            <MudText Typo="Typo.caption" Class="mr-1">/ @Goal</MudText>
        }
        @if (FormFieldType == WorkoutFormFieldType.Duration)
        {
            <MudIconButton Size="Size.Small" OnClick="OpenTimer"
                Icon="@Icons.Material.Filled.Timer" Color="Color.Secondary" />
        }
    </AdornmentEnd>
</MudTextFieldExtended>

@code {

    [Parameter]
    public WorkoutFormFieldType FormFieldType { get; set; }

    [Parameter]
    public string? TitlePrefix { get; set; }

    [Parameter]
    public int? Goal { get; set; } = null;

    [Parameter]
    public int? EnterValue { get; set; } = null;

    [Parameter]
    public EventCallback<int?> EnterValueChanged { get; set; }

    async void OnChange(int? value)
    {
        await EnterValueChanged.InvokeAsync(value);
    }

    private string Icon => FormFieldType switch
    {
        WorkoutFormFieldType.Reps => Icons.Material.Filled._123,
        WorkoutFormFieldType.Weight => Icons.Material.Filled.FitnessCenter,
        WorkoutFormFieldType.Duration => Icons.Material.Filled.Timer,
        _ => Icons.Material.Filled._123
    };

    private string InternalTitle
    {
        get
        {
            var title = FormFieldType switch
            {
                WorkoutFormFieldType.Reps => "Reps",
                WorkoutFormFieldType.Weight => "Weight",
                WorkoutFormFieldType.Duration => "Duration",
                _ => ""
            };
            return string.IsNullOrEmpty(TitlePrefix) ? title : $"{TitlePrefix} {title}";
        }
    }

    public enum WorkoutFormFieldType
    {
        Reps,
        Weight,
        Duration
    }

    private async Task OpenTimer()
    {
        var parameters = new DialogParameters<TimerDialog> { { x => x.Goal, Goal ?? 0 } };
        var options = new DialogOptions 
        { 
            MaxWidth = MaxWidth.ExtraSmall,
            BackdropClick = false,
            CloseButton = true,
        };
        await DialogService.ShowAsync<TimerDialog>("Timer", parameters, options);
    }
}
