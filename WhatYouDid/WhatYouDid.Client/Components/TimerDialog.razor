@using System.Timers
@using Radzen
@inject DialogService DialogService
@inject IJSRuntime JS

<RadzenStack>
    <div style="font-size:2rem;font-weight:600;text-align:center;color:@(ReachedGoal ? "green" : "inherit")">@FormatTime(_elapsedSeconds)</div>

    @if (Goal > 0)
    {
        <div style="text-align:center;color:var(--rz-secondary);font-size:0.9rem;">Target: @FormatTime(Goal)</div>
    }

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.Center">
        <RadzenButton Size="ButtonSize.Medium" Click="Start" Disabled="_running" ButtonStyle="ButtonStyle.Secondary" Icon="play_arrow" Title="Start" />
        <RadzenButton Size="ButtonSize.Medium" Click="Stop" Disabled="!_running" ButtonStyle="ButtonStyle.Secondary" Icon="pause" Title="Pause" />
        <RadzenButton Size="ButtonSize.Medium" Click="Reset" ButtonStyle="ButtonStyle.Secondary" Icon="refresh" Title="Reset" />
    </RadzenStack>
</RadzenStack>


@code {
    private Timer? _timer;
    private bool _running;
    private int _elapsedSeconds;


    [Parameter]
    public int Goal { get; set; } = 0;
    private bool ReachedGoal => Goal > 0 && _elapsedSeconds >= Goal;

    private async Task Start()
    {
        if (_running)
            return;

        if (_timer == null)
        {
            _timer = new Timer(1000);
            _timer.Elapsed += OnTick;
            _timer.AutoReset = true;
        }

        await JS.InvokeVoidAsync("wakeLockHelper.enable");

        _timer.Start();
        _running = true;
    }

    private async Task Stop()
    {
        if (_timer == null)
            return;

        _timer.Stop();
        _running = false;

        await JS.InvokeVoidAsync("wakeLockHelper.disable");
    }

    private async Task Reset()
    {
        await Stop();
        _elapsedSeconds = 0;
        await InvokeAsync(StateHasChanged);
    }

    private void OnTick(object? sender, ElapsedEventArgs e)
    {
        _elapsedSeconds++;
        InvokeAsync(StateHasChanged);
    }

    private string FormatTime(int seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        return ts.ToString("mm\\:ss");
    }

    private void Close()
    {
        try
        {
            DialogService.Close(_elapsedSeconds);
        }
        catch { }
    }

    public void Dispose()
    {
        try
        {
            if (_timer != null)
            {
                _timer.Elapsed -= OnTick;
                _timer.Dispose();
                _timer = null;
            }
        }
        catch { }
    }
}
