@using WhatYouDid.Shared
@inject IRoutineService RoutineService
@inject NavigationManager Navigation
@inject IBrowserStorage BrowserStorage
@inject IDialogService DialogService

<MudCard Class="routine-card">
    <MudCardContent>
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center"
                  @onclick="ToggleExpanded" Style="cursor:pointer">
            <MudText Typo="Typo.h6" Style="margin: 0">@Name</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudIcon Icon="@(expanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                         Style="color: var(--mud-palette-text-secondary); font-size: 1.75rem" />
                <span @onclick:stopPropagation="true">
                    @if (_hasInProgress)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline"
                                       Color="Color.Error"
                                       Size="Size.Medium"
                                       Style="opacity: 0.5"
                                       title="Discard in-progress workout"
                                       OnClick="DiscardWorkout" />
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ContinueWorkout"
                                   title="Continue workout" Style="min-width: unset; padding: 6px 8px">
                            <span style="position: relative; display: inline-flex; font-size: 1.5rem">
                                <MudIcon Icon="@Icons.Material.Filled.PlayArrow" />
                                @if (_progressTotal > 0)
                                {
                                    <span style="font-size: 0.625rem; position: absolute; bottom: -2px; right: -6px; line-height: 1">@_progressIndex/@_progressTotal</span>
                                }
                            </span>
                        </MudButton>
                    }
                    else
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="StartWorkout"
                                   title="Start workout" Style="min-width: unset; padding: 6px 8px">
                            <span style="position: relative; display: inline-flex; font-size: 1.5rem">
                                <MudIcon Icon="@Icons.Material.Filled.PlayArrow" />
                                <MudIcon Icon="@Icons.Material.Filled.Add"
                                         Style="font-size: 0.875rem; position: absolute; bottom: -2px; right: -4px" />
                            </span>
                        </MudButton>
                    }
                </span>
            </MudStack>
        </MudStack>

        @if (expanded)
        {
            <MudStack Spacing="1" Style="margin-top: 12px">
                @if (exercises is null)
                {
                    <MudProgressLinear Indeterminate="true" />
                }
                else
                {
                    @foreach (var exercise in exercises)
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="padding: 6px 0; border-top: 1px solid var(--mud-palette-divider)">
                            <MudText Style="flex: 1; margin: 0">@exercise.Sequence. @exercise.Name</MudText>
                            <MudText Typo="Typo.caption" Style="margin: 0; color: var(--mud-palette-text-secondary)">@exercise.Sets set@(exercise.Sets != 1 ? "s" : "")</MudText>
                            <MudStack Row="true" Spacing="0">
                                <MudIcon Icon="@Icons.Material.Filled._123" Style="@(exercise.HasReps ? "opacity: 1.0; font-size: 1rem" : "opacity: 0.15; font-size: 1rem")" />
                                <MudIcon Icon="@Icons.Material.Filled.FitnessCenter" Style="@(exercise.HasWeight ? "opacity: 1.0; font-size: 1rem" : "opacity: 0.15; font-size: 1rem")" />
                                <MudIcon Icon="@Icons.Material.Filled.Timer" Style="@(exercise.HasDuration ? "opacity: 1.0; font-size: 1rem" : "opacity: 0.15; font-size: 1rem")" />
                            </MudStack>
                        </MudStack>
                    }
                }
            </MudStack>
        }
    </MudCardContent>
</MudCard>

@code {

    [Parameter, EditorRequired]
    public required string Name { get; set; }

    [Parameter, EditorRequired]
    public required int RoutineId { get; set; }

    bool expanded = false;
    bool _hasInProgress = false;
    int _progressIndex = 0;
    int _progressTotal = 0;
    List<ExerciseDto>? exercises;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var existing = await BrowserStorage.GetAsync<WorkoutDto>($"Workout_{Name}_{RoutineId}");
            if (existing != null)
            {
                _hasInProgress = true;
                _progressIndex = existing.ExerciseIndex;
                _progressTotal = existing.WorkoutExercises?.Count ?? 0;
                StateHasChanged();
            }
        }
    }

    async Task ToggleExpanded()
    {
        expanded = !expanded;
        if (expanded && exercises is null)
            exercises = await RoutineService.GetExercisesAsync(RoutineId);
    }

    void StartWorkout() => Navigation.NavigateTo($"/workout/{RoutineId}");

    void ContinueWorkout() => Navigation.NavigateTo($"/workout/{RoutineId}");

    async Task DiscardWorkout()
    {
        bool? confirmed = await DialogService.ShowMessageBoxAsync(
            "Discard workout?",
            "This will discard your in-progress workout.",
            yesText: "Discard", cancelText: "Cancel");
        if (confirmed == true)
        {
            await BrowserStorage.DeleteAsync($"Workout_{Name}_{RoutineId}");
            _hasInProgress = false;
        }
    }
}
