@page "/progress"
@using WhatYouDid.Shared
@using MudBlazor.Charts
@attribute [Authorize]
@rendermode InteractiveWebAssembly
@implements IDisposable

@inject IRoutineService RoutineService
@inject IWorkoutService WorkoutService

<MudPopoverProvider />

<PageTitle>Progress</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Progress</MudText>

<MudGrid Class="mb-2" Spacing="2">
    <MudItem xs="12" sm="5">
        <MudSelect T="RoutineDto"
            Label="Routine"
            Value="selectedRoutine"
            ValueChanged="OnRoutineSelected"
            ToStringFunc="r => r?.Name ?? string.Empty"
            Variant="Variant.Outlined"
            Disabled="routines.Count == 0">
            @foreach (var routine in routines)
            {
                <MudSelectItem Value="@routine">@routine.Name</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
    <MudItem xs="12" sm="5">
        <MudSelect T="ExerciseDto"
            Label="Exercise"
            Value="selectedExercise"
            ValueChanged="OnExerciseSelected"
            ToStringFunc="e => e is null ? string.Empty : ExerciseLabel(e)"
            Variant="Variant.Outlined"
            Disabled="exercises.Count == 0">
            @foreach (var exercise in exercises)
            {
                <MudSelectItem Value="@exercise">@ExerciseLabel(exercise)</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
    <MudItem xs="12" sm="2" Style="display:flex; align-items:center">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth="true"
                   Disabled="selectedExercise is null || isLoading"
                   OnClick="LoadHistory">
            Load
        </MudButton>
    </MudItem>
</MudGrid>

@if (isLoading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (history is not null)
{
    @if (history.HasReps)
    {
        <MudCard Class="mb-4">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-2">Reps</MudText>
                @if (repsSeries.Count > 0)
                {
                    <Line T="double"
                          ChartSeries="repsSeries"
                          ChartLabels="xLabels"
                          ChartOptions="chartOptions"
                          Width="100%" Height="300px" />
                }
            </MudCardContent>
        </MudCard>
    }

    @if (history.HasWeight)
    {
        <MudCard Class="mb-4">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-2">Weight (lbs)</MudText>
                @if (weightSeries.Count > 0)
                {
                    <Line T="double"
                          ChartSeries="weightSeries"
                          ChartLabels="xLabels"
                          ChartOptions="chartOptions"
                          Width="100%" Height="300px" />
                }
            </MudCardContent>
        </MudCard>
    }

    @if (history.HasDuration)
    {
        <MudCard Class="mb-4">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-2">Duration (sec)</MudText>
                @if (durationSeries.Count > 0)
                {
                    <Line T="double"
                          ChartSeries="durationSeries"
                          ChartLabels="xLabels"
                          ChartOptions="chartOptions"
                          Width="100%" Height="300px" />
                }
            </MudCardContent>
        </MudCard>
    }
}
else if (noHistory)
{
    <MudText Color="Color.Secondary">No history found for "@ExerciseLabel(selectedExercise!)".</MudText>
}

@code {
    List<RoutineDto> routines = [];
    List<ExerciseDto> exercises = [];
    RoutineDto? selectedRoutine;
    ExerciseDto? selectedExercise;
    ExerciseHistoryDto? history;
    bool isLoading;
    bool noHistory;

    CancellationTokenSource _cts = new();

    string[] xLabels = [];
    List<ChartSeries<double>> repsSeries = [];
    List<ChartSeries<double>> weightSeries = [];
    List<ChartSeries<double>> durationSeries = [];

    readonly LineChartOptions chartOptions = new()
    {
        LineStrokeWidth = 2,
        YAxisTicks = 5,
    };

    protected override async Task OnInitializedAsync()
    {
        routines = await RoutineService.GetUserRoutinesAsync(performedOnly: true);
    }

    private async Task OnRoutineSelected(RoutineDto? routine)
    {
        _cts.Cancel();
        _cts = new CancellationTokenSource();
        var token = _cts.Token;

        selectedRoutine = routine;
        selectedExercise = null;
        exercises = [];
        ClearChartData();

        if (routine is null) return;

        try
        {
            var result = await RoutineService.GetExercisesAsync(routine.RoutineId);
            if (!token.IsCancellationRequested)
                exercises = result;
        }
        catch (OperationCanceledException) { }
    }

    private void OnExerciseSelected(ExerciseDto? exercise)
    {
        selectedExercise = exercise;
        ClearChartData();
    }

    private async Task LoadHistory()
    {
        if (selectedExercise is null) return;

        _cts.Cancel();
        _cts = new CancellationTokenSource();
        var token = _cts.Token;

        isLoading = true;
        noHistory = false;
        try
        {
            var result = await WorkoutService.GetExerciseHistoryAsync(selectedExercise.ExerciseId);
            if (token.IsCancellationRequested) return;

            history = result;
            if (history is not null)
                BuildChartData(history);
            else
                noHistory = true;
        }
        catch (OperationCanceledException) { }
        finally
        {
            if (!token.IsCancellationRequested)
                isLoading = false;
        }
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }

    // Appends sequence number only when the same exercise name appears more than once
    // in the current routine (e.g. "Push-Ups" and "Push-Ups (#3)").
    private string ExerciseLabel(ExerciseDto ex) =>
        exercises.Count(e => e.Name == ex.Name) > 1
            ? $"{ex.Name} (#{ex.Sequence})"
            : ex.Name;

    private void ClearChartData()
    {
        history = null;
        noHistory = false;
        xLabels = [];
        repsSeries = [];
        weightSeries = [];
        durationSeries = [];
    }

    private void BuildChartData(ExerciseHistoryDto h)
    {
        var sessions = h.Sessions;

        xLabels = sessions
            .Select(s => s.Date.LocalDateTime.ToString("MMM d"))
            .ToArray();

        int maxSets = Math.Min(sessions.Max(s => s.Sets.Count), 6);

        if (h.HasReps)
            repsSeries = BuildSeries(sessions, maxSets, s => (double?)s.Reps);

        if (h.HasWeight)
            weightSeries = BuildSeries(sessions, maxSets, s => (double?)s.Weight);

        if (h.HasDuration)
            durationSeries = BuildSeries(sessions, maxSets, s => (double?)s.Duration);
    }

    private static List<ChartSeries<double>> BuildSeries(
        List<ExerciseSessionHistoryDto> sessions,
        int maxSets,
        Func<ExerciseSetHistoryDto, double?> getValue)
    {
        var series = new List<ChartSeries<double>>();
        for (int setNum = 1; setNum <= maxSets; setNum++)
        {
            var captured = setNum;
            var data = sessions.Select(session =>
            {
                var set = session.Sets.FirstOrDefault(s => s.SetNumber == captured);
                if (set is null) return double.NaN;
                return getValue(set) ?? double.NaN;
            }).ToArray();

            if (data.Any(v => !double.IsNaN(v)))
            {
                series.Add(new ChartSeries<double>
                {
                    Name = maxSets == 1 ? "" : $"Set {captured}",
                    Data = data,
                });
            }
        }
        return series;
    }
}
