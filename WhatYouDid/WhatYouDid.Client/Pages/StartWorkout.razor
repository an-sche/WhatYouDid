@page "/workout/{RoutineId:int}"

@using WhatYouDid.Shared
@using Microsoft.AspNetCore.Authorization
@using WhatYouDid.Client.Components
@using System.Text
@using System.Security.Claims
@attribute [Authorize]
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject IBrowserStorage BrowserStorage
@inject DialogService DialogService
@inject NavigationManager Navigation
@inject HttpClient Http

@if (WorkoutDto is null) {
	if (Loaded)
	{
		<RadzenText TextStyle="TextStyle.H4">Invalid Permissions</RadzenText>
	}
	else 
	{
		<RadzenText TextStyle="TextStyle.H4">Loading...</RadzenText>
	}
	return;
}

<RadzenText TextStyle="TextStyle.H4">@WorkoutDto.RoutineName</RadzenText>

@if (WorkoutDto.ExerciseIndex < WorkoutDto.WorkoutExercises?.Count) {
	string unit = " of " + @WorkoutDto.WorkoutExercises?.Count;
	<RadzenProgressBar ProgressBarStyle="ProgressBarStyle.Light" Value="@(WorkoutDto.ExerciseIndex + 1)" Max="@(WorkoutDto.WorkoutExercises?.Count ?? 0)" Unit="@unit" />
}

<div class="exercise-wrapper">
	@if (WorkoutDto.ExerciseIndex < @WorkoutDto.WorkoutExercises?.Count)
	{
		// This is where i put the information for them to fill out!
		<RadzenDropDown Class="rz-m-2"
			Value="@WorkoutDto.WorkoutExercises[WorkoutDto.ExerciseIndex].ExerciseName" 
			Data="@ExerciseNames" 
			Change="@OnDropdownValueChanged" />

		var workoutExercise = WorkoutDto.WorkoutExercises[WorkoutDto.ExerciseIndex];
		
		<RadzenStack @key="@workoutExercise.ExerciseName" 
			Orientation="Orientation.Vertical" 
			JustifyContent="JustifyContent.Normal"
			Class="@SlidingClass">

			@for (int i = 0; i < workoutExercise.Sets; i++)
			{
				var index = i; // capture the loop variable
				<RadzenCard Variant="Variant.Outlined">
					<RadzenText TextStyle="TextStyle.Caption">Set: @(index + 1)</RadzenText>

					@if (workoutExercise.HasReps)
					{
						int? repGoal = null;
						if (@workoutExercise.LastReps != null && workoutExercise.LastReps.Length > index)
						{
							repGoal = @workoutExercise.LastReps[index];
						}
						<WorkoutFormField FormFieldType="WorkoutFormField.WorkoutFormFieldType.Reps"
						@bind-EnterValue="@workoutExercise.Reps[index]" 
						Goal="@repGoal" />
					}

					@if (workoutExercise.HasWeights)
					{
						int? weightGoal = null;
						if (@workoutExercise.LastWeights != null && workoutExercise.LastWeights.Length > index)
						{
							weightGoal = @workoutExercise.LastWeights[index];
						}
						<WorkoutFormField FormFieldType="WorkoutFormField.WorkoutFormFieldType.Weight"
						@bind-EnterValue="@workoutExercise.Weights[index]"
						Goal="@weightGoal" />
					}

					@if (workoutExercise.HasDurations)
					{
						int? durationGoal = null;
						@if (@workoutExercise.LastDurations != null && workoutExercise.LastDurations.Length > index)
						{
							durationGoal = @workoutExercise.LastDurations[index];
						}

						<WorkoutFormField FormFieldType="WorkoutFormField.WorkoutFormFieldType.Duration"
						@bind-EnterValue="@workoutExercise.Durations[index]"
						Goal="@durationGoal" />
					}
				</RadzenCard>
			}
		</RadzenStack>

		<RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" >
			<RadzenButton Class="rz-m-2" Style="min-width: 100px" Icon="arrow_back" Click=@OnBackClick ButtonStyle="ButtonStyle.Secondary" Disabled="WorkoutDto.ExerciseIndex == 0" />
			<RadzenButton Class="rz-m-2" Style="min-width: 100px" Icon="arrow_forward" Click=@OnNextClick ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Submit" />
		</RadzenStack>
	}
	else {

		<RadzenText TextStyle="TextStyle.H5">Review</RadzenText>
		<RadzenDataGrid Data="@WorkoutDto.WorkoutExercises" TItem="WorkoutExerciseDto" class="slide-from-right"> 
			<Columns>
				<RadzenDataGridColumn TItem="WorkoutExerciseDto" Property="Sequence" Title="#" Width="50px"/> 
				<RadzenDataGridColumn TItem="WorkoutExerciseDto" Property="ExerciseName" Title="Exercise" />
				<RadzenDataGridColumn TItem="WorkoutExerciseDto" Property="Review" Title="Review" />
			</Columns>
		</RadzenDataGrid>

		<RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" >
			<RadzenButton Class="rz-m-2" Style="min-width: 100px" Icon="arrow_back" Click=@OnBackClick ButtonStyle="ButtonStyle.Secondary" />
			<RadzenButton Class="rz-m-2" Style="min-width: 100px" IsBusy=@Saving Click=@OnSubmitClick Text="Submit" ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Submit"/>
		</RadzenStack>
	}	
</div>

<style>
	@@keyframes slideInFromRight {
		from {
			transform: translateX(100%);
			opacity: 0;
		}

		to {
			transform: translateX(0);
			opacity: 100;
		}
	}

	.slide-from-right {
		animation-duration: 333ms;
		animation-timing-function: ease-out; 
		animation-delay: 0s; 
		animation-iteration-count: 1; 
		animation-name: slideInFromRight; 
	}

	@@keyframes slideInFromLeft {
		from {
			transform: translateX(-100%);
			opacity: 0;
		}

		to {
			transform: translateX(0);
			opacity: 100;
		}
	}

	.slide-from-left {
		animation-duration: 333ms;
		animation-timing-function: ease-out;
		animation-delay: 0s;
		animation-iteration-count: 1;
		animation-name: slideInFromLeft; 
	}

	/* prevents animations from going outside the exercise window (over the menu) */
	.exercise-wrapper {
		position: relative;
		overflow: hidden;
		width: 100%;
	}

</style>

@code {

	[Parameter]
	public int RoutineId { get; set; }

	[CascadingParameter]
	private Task<AuthenticationState>? authenticationState { get; set; }

	public WorkoutDto? WorkoutDto { get; set; }
	public string[] ExerciseNames { get; set; } = [];

	public bool Loaded = false;
	public bool Saving = false;

	private bool AlreadyAsked = false; // Field to know if we need to check browser storage
	private string SlidingClass = "slide-from-right";

	protected override async Task OnInitializedAsync()
	{
		if (authenticationState is null)
			return;

		// Tenant is resolved server-side; call API without passing user id
		// WorkoutDto = await Api.GetStartWorkoutDtoAsync(RoutineId);
		WorkoutDto = await Http.GetFromJsonAsync<WorkoutDto>(
			$"api/workouts/start/{RoutineId}");

		Loaded = true;
		if (WorkoutDto is not null)
		{
			ExerciseNames = WorkoutDto.WorkoutExercises?
				.Select(w => $"{w.Sequence}: {w.ExerciseName}").ToArray() ?? new string[0];
		}

		await base.OnInitializedAsync();
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (!AlreadyAsked && WorkoutDto != null)
		{
			AlreadyAsked = true;

			var browserDto = await BrowserStorage.GetAsync<WorkoutDto>(WorkoutDto.GetBrowserStorageId);

			if (browserDto != null)
			{
				// Ask the user if they wanna do that one
				var startNew = await DialogService.Confirm("You have an unfinished workout.\n\nContinue previous workout or start new?", "Confirm",
					new ConfirmOptions() { OkButtonText = "Start New", CancelButtonText = "Continue previous" }) ?? false;

				if (startNew)
				{
					// Start a new one
					await BrowserStorage.SetAsync(WorkoutDto.GetBrowserStorageId, WorkoutDto);
				}
				else
				{
					// Continue the old one
					WorkoutDto = browserDto;
					await InvokeAsync(StateHasChanged);
				}
			}

		}

		await base.OnAfterRenderAsync(firstRender);
	}

	private async Task OnDropdownValueChanged(object item)
	{
		if (WorkoutDto is null
			|| WorkoutDto.WorkoutExercises is null)
		{
			return;
		}

		if (item is not string exercise)
		{
			return;
		}

		var newIndex = ExerciseNames.IndexOf(exercise);
		if (newIndex < 0 || newIndex == WorkoutDto.WorkoutExercises?.Count)
		{
			return;
		}

		SlidingClass = (newIndex < WorkoutDto.ExerciseIndex)
			? "slide-from-left"
			: "slide-from-right";

		WorkoutDto.ExerciseIndex = newIndex;
	}

	private async Task OnBackClick() 
	{
		if (WorkoutDto is null) return;

        SlidingClass = "slide-from-left";

		if (WorkoutDto.ExerciseIndex > 0)
			WorkoutDto.ExerciseIndex--;

		await BrowserStorage.SetAsync(WorkoutDto.GetBrowserStorageId, WorkoutDto);

		await InvokeAsync(StateHasChanged);
	}

	private async Task OnNextClick()
	{
		if (WorkoutDto is null) return;
		
		SlidingClass = "slide-from-right";

		if (WorkoutDto.ExerciseIndex < WorkoutDto.WorkoutExercises?.Count)
			WorkoutDto.ExerciseIndex++;

		await BrowserStorage.SetAsync(WorkoutDto.GetBrowserStorageId, WorkoutDto);
		
		await InvokeAsync(StateHasChanged);
	}

	private async Task OnSubmitClick() 
	{
		// Save the workout they created to the database
		if (WorkoutDto is null) return;	
		if (Saving) return;
		Saving = true;
		StateHasChanged();

		try
		{
			var response = await Http.PostAsJsonAsync("api/workouts", WorkoutDto);
			
			response.EnsureSuccessStatusCode();
			try
			{
				await BrowserStorage.DeleteAsync(WorkoutDto.GetBrowserStorageId);
			}
			catch { }

			// Send the user to the Workouts page...
			Navigation.NavigateTo("/workouts");
		}
		catch { }
		finally { Saving = false; }
	}
}
