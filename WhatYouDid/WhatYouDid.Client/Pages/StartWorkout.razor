@page "/workout/{RoutineId:int}"

@using System.Text
@using System.Security.Claims
@using WhatYouDid.Client.Components
@using WhatYouDid.Shared

@attribute [Authorize]
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject IBrowserStorage BrowserStorage
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject HttpClient Http

<MudPopoverProvider />
<MudDialogProvider /> 
<MudSnackbarProvider />

@if (WorkoutDto is null) {
	<MudText Typo="Typo.h4">Loading...</MudText>
	return;
}

<MudText Typo="Typo.h4">@WorkoutDto.RoutineName</MudText>

@if (WorkoutDto.ExerciseIndex < WorkoutDto.WorkoutExercises?.Count) {
	int curr = WorkoutDto.ExerciseIndex + 1;
	int max = WorkoutDto.WorkoutExercises?.Count ?? 0;
	string display = curr + " of " + max;
	<MudProgressLinear Color="Color.Default" Value="@curr" Max="@max" Size="Size.Large">
		<MudText Typo="Typo.subtitle1" Style="color: white">
			<b>@display</b>
		</MudText>
	</MudProgressLinear>
}

<div class="exercise-wrapper">
	@if (WorkoutDto.ExerciseIndex < @WorkoutDto.WorkoutExercises?.Count)
	{
		var workoutExercise = WorkoutDto.WorkoutExercises[WorkoutDto.ExerciseIndex];
		bool hasLastValues = (workoutExercise.HasReps || workoutExercise.HasWeights || workoutExercise.HasDurations)
			&& ((workoutExercise.LastReps?.Any(r => r != null) == true) ||
			(workoutExercise.LastWeights?.Any(w => w != null) == true) ||
			(workoutExercise.LastDurations?.Any(d => d != null) == true));

		<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="ma-2" Style="overflow: hidden">
			<div style="flex: 1; min-width: 0; overflow: hidden">
				<MudSelect T="string" Dense FullWidth="true"
					Value="@ExerciseNames.ElementAtOrDefault(WorkoutDto.ExerciseIndex)"
					ValueChanged="@OnDropdownValueChanged"
					Variant="Variant.Outlined">
					@foreach (var name in ExerciseNames)
					{
						<MudSelectItem T="string" Value="@name">@name</MudSelectItem>
					}
				</MudSelect>
			</div>
			@if (hasLastValues)
			{
				<MudIconButton Color="Color.Default" Size="Size.Small"
					Icon="@Icons.Material.Filled.History" OnClick="OnAutofillLastTime" aria-label="Autofill from last workout" />
			}
		</MudStack>

		<MudStack @key="@workoutExercise.ExerciseName"
			Spacing="0"
			Class="@SlidingClass"
			id="exercise-stack">

			@for (int i = 0; i < workoutExercise.Sets; i++)
			{
				var index = i;
				<MudCard Outlined="true" Class="mb-2">
					<MudCardContent>
						<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
							<MudText Typo="Typo.caption">Set: @(index + 1)</MudText>
							<MudButton Size="Size.Small" Variant="Variant.Outlined" tabindex="-1"
								StartIcon="@(IsAlternateExpanded(WorkoutDto.ExerciseIndex, index) || HasAnyAlternateData(workoutExercise, index) || HasAnyLastAlternateData(workoutExercise, index) ? Icons.Material.Filled.Remove : Icons.Material.Filled.Add)"
								Disabled="@HasAnyLastAlternateData(workoutExercise, index)"
								OnClick="@(() => ToggleAlternate(WorkoutDto.ExerciseIndex, index))">Alt</MudButton>
						</MudStack>

						<MudStack Spacing="1">
						@if (workoutExercise.HasReps)
						{
							int? repGoal = null;
							if (@workoutExercise.LastReps != null && workoutExercise.LastReps.Length > index)
							{
								repGoal = @workoutExercise.LastReps[index];
							}
							<WorkoutFormField FormFieldType="WorkoutFormField.WorkoutFormFieldType.Reps"
							@bind-EnterValue="@workoutExercise.Reps[index]"
							Goal="@repGoal" />
						}

						@if (workoutExercise.HasWeights)
						{
							int? weightGoal = null;
							if (@workoutExercise.LastWeights != null && workoutExercise.LastWeights.Length > index)
							{
								weightGoal = @workoutExercise.LastWeights[index];
							}
							<WorkoutFormField FormFieldType="WorkoutFormField.WorkoutFormFieldType.Weight"
							@bind-EnterValue="@workoutExercise.Weights[index]"
							Goal="@weightGoal" />
						}

						@if (workoutExercise.HasDurations)
						{
							int? durationGoal = null;
							@if (@workoutExercise.LastDurations != null && workoutExercise.LastDurations.Length > index)
							{
								durationGoal = @workoutExercise.LastDurations[index];
							}

							<WorkoutFormField FormFieldType="WorkoutFormField.WorkoutFormFieldType.Duration"
							@bind-EnterValue="@workoutExercise.Durations[index]"
							Goal="@durationGoal" />
						}
						</MudStack>

			@if (IsAlternateExpanded(WorkoutDto.ExerciseIndex, index) || HasAnyAlternateData(workoutExercise, index) || HasAnyLastAlternateData(workoutExercise, index))
					{
						<MudStack Spacing="1" Style="border-left: 2px solid var(--mud-palette-secondary-lighten); padding-left: 8px; margin-top: 4px">
							@if (workoutExercise.HasReps)
							{
								int? altRepGoal = workoutExercise.LastAlternateReps != null && workoutExercise.LastAlternateReps.Length > index ? workoutExercise.LastAlternateReps[index] : null;
								<WorkoutFormField FormFieldType="WorkoutFormField.WorkoutFormFieldType.Reps"
									TitlePrefix="Alt"
									@bind-EnterValue="@workoutExercise.AlternateReps[index]"
									Goal="@altRepGoal" />
							}
							@if (workoutExercise.HasWeights)
							{
								int? altWeightGoal = workoutExercise.LastAlternateWeights != null && workoutExercise.LastAlternateWeights.Length > index ? workoutExercise.LastAlternateWeights[index] : null;
								<WorkoutFormField FormFieldType="WorkoutFormField.WorkoutFormFieldType.Weight"
									TitlePrefix="Alt"
									@bind-EnterValue="@workoutExercise.AlternateWeights[index]"
									Goal="@altWeightGoal" />
							}
							@if (workoutExercise.HasDurations)
							{
								int? altDurationGoal = workoutExercise.LastAlternateDurations != null && workoutExercise.LastAlternateDurations.Length > index ? workoutExercise.LastAlternateDurations[index] : null;
								<WorkoutFormField FormFieldType="WorkoutFormField.WorkoutFormFieldType.Duration"
									TitlePrefix="Alt"
									@bind-EnterValue="@workoutExercise.AlternateDurations[index]"
									Goal="@altDurationGoal" />
							}
							<MudTextField T="string" Label="Note" @bind-Value="@workoutExercise.Notes[index]" FullWidth="true" Variant="Variant.Outlined" />
							@{
								string? lastNote = workoutExercise.LastNotes != null && workoutExercise.LastNotes.Length > index ? workoutExercise.LastNotes[index] : null;
							}
							@if (lastNote != null)
							{
								<MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary)">Last: @lastNote</MudText>
							}
						</MudStack>
					}
					</MudCardContent>
				</MudCard>
			}
		</MudStack>

		<MudStack Row="true" Spacing="2" Style="margin: 0.5rem">
			<MudButton Style="flex:1" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick=@OnBackClick Color="Color.Secondary" Variant="Variant.Filled" Size="Size.Large" Disabled="WorkoutDto.ExerciseIndex == 0" aria-label="Previous exercise" />
			<MudButton Style="flex:1" StartIcon="@Icons.Material.Filled.ArrowForward" OnClick=@OnNextClick Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large" aria-label="Next exercise" />
		</MudStack>
	}
	else {

		<MudText Typo="Typo.h5">Review</MudText>
		<WorkoutReview Workout="@WorkoutDto" />

		<MudStack Row="true" Spacing="2" Style="margin: 0.5rem">
			<MudButton Style="flex:1" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick=@OnBackClick Color="Color.Secondary" Variant="Variant.Filled" Size="Size.Large" aria-label="Previous exercise" />
			<MudButton Style="flex:1" Disabled="@Saving" OnClick=@OnSubmitClick StartIcon="@Icons.Material.Filled.CheckCircle" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large" aria-label="Finish Workout">Finish Workout</MudButton>
		</MudStack>
	}
</div>

<style>
	@@keyframes slideInFromRight {
		from {
			transform: translateX(100%);
			opacity: 0;
		}

		to {
			transform: translateX(0);
			opacity: 100;
		}
	}

	.slide-from-right {
		animation-duration: 333ms;
		animation-timing-function: ease-out;
		animation-delay: 0s;
		animation-iteration-count: 1;
		animation-name: slideInFromRight;
	}

	@@keyframes slideInFromLeft {
		from {
			transform: translateX(-100%);
			opacity: 0;
		}

		to {
			transform: translateX(0);
			opacity: 100;
		}
	}

	.slide-from-left {
		animation-duration: 333ms;
		animation-timing-function: ease-out;
		animation-delay: 0s;
		animation-iteration-count: 1;
		animation-name: slideInFromLeft;
	}

	/* prevents animations from going outside the exercise window (over the menu) */
	.exercise-wrapper {
		position: relative;
		overflow-x: hidden;
		width: 100%;
		padding-bottom: 3rem;
	}

</style>

@code {

	[Parameter]
	public int RoutineId { get; set; }

	public WorkoutDto? WorkoutDto { get; set; }
	public string[] ExerciseNames { get; set; } = [];

	public bool Saving = false;

	private bool AlreadyAsked = false;
	private string SlidingClass = "slide-from-right";
	private HashSet<(int exerciseIndex, int setIndex)> _expandedAlternates = new();

	private bool IsAlternateExpanded(int exerciseIndex, int setIndex)
		=> _expandedAlternates.Contains((exerciseIndex, setIndex));

	private void ToggleAlternate(int exerciseIndex, int setIndex)
	{
		var key = (exerciseIndex, setIndex);
		if (!_expandedAlternates.Remove(key))
			_expandedAlternates.Add(key);
	}

	private bool HasAnyAlternateData(WorkoutExerciseDto exercise, int setIndex)
	{
		return (exercise.AlternateReps.Length > setIndex && exercise.AlternateReps[setIndex] != null)
			|| (exercise.AlternateWeights.Length > setIndex && exercise.AlternateWeights[setIndex] != null)
			|| (exercise.AlternateDurations.Length > setIndex && exercise.AlternateDurations[setIndex] != null)
			|| (exercise.Notes.Length > setIndex && !string.IsNullOrEmpty(exercise.Notes[setIndex]));
	}

	private bool HasAnyLastAlternateData(WorkoutExerciseDto exercise, int setIndex)
	{
		return (exercise.LastAlternateReps != null && exercise.LastAlternateReps.Length > setIndex && exercise.LastAlternateReps[setIndex] != null)
			|| (exercise.LastAlternateWeights != null && exercise.LastAlternateWeights.Length > setIndex && exercise.LastAlternateWeights[setIndex] != null)
			|| (exercise.LastAlternateDurations != null && exercise.LastAlternateDurations.Length > setIndex && exercise.LastAlternateDurations[setIndex] != null)
			|| (exercise.LastNotes != null && exercise.LastNotes.Length > setIndex && !string.IsNullOrEmpty(exercise.LastNotes[setIndex]));
	}

	protected override async Task OnInitializedAsync()
	{
		WorkoutDto = await Http.GetFromJsonAsync<WorkoutDto>(
			$"api/workouts/start/{RoutineId}");

		if (WorkoutDto is not null)
		{
			WorkoutDto.StartTime = DateTimeOffset.Now;
			ExerciseNames = WorkoutDto.WorkoutExercises?
				.Select(w => $"{w.Sequence}: {w.ExerciseName}").ToArray() ?? new string[0];
		}

		await base.OnInitializedAsync();
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (!AlreadyAsked && WorkoutDto != null)
		{
			AlreadyAsked = true;

			var browserDto = await BrowserStorage.GetAsync<WorkoutDto>(WorkoutDto.GetBrowserStorageId);

			if (browserDto != null)
			{
				WorkoutDto = browserDto;
				await InvokeAsync(StateHasChanged);
			}

		}

		await base.OnAfterRenderAsync(firstRender);
	}

	private async Task OnDropdownValueChanged(string exercise)
	{
		if (WorkoutDto is null || WorkoutDto.WorkoutExercises is null)
			return;

		var newIndex = ExerciseNames.IndexOf(exercise);
		if (newIndex < 0 || newIndex == WorkoutDto.WorkoutExercises?.Count)
			return;

		SlidingClass = (newIndex < WorkoutDto.ExerciseIndex)
			? "slide-from-left"
			: "slide-from-right";

		WorkoutDto.ExerciseIndex = newIndex;
	}

	private void OnAutofillLastTime()
	{
		if (WorkoutDto?.WorkoutExercises is null) return;
		var ex = WorkoutDto.WorkoutExercises[WorkoutDto.ExerciseIndex];
		for (int i = 0; i < ex.Sets; i++)
		{
			if (ex.HasReps && ex.LastReps != null && ex.LastReps.Length > i)
				ex.Reps[i] = ex.LastReps[i];
			if (ex.HasWeights && ex.LastWeights != null && ex.LastWeights.Length > i)
				ex.Weights[i] = ex.LastWeights[i];
			if (ex.HasDurations && ex.LastDurations != null && ex.LastDurations.Length > i)
				ex.Durations[i] = ex.LastDurations[i];

			if (ex.HasReps && ex.LastAlternateReps != null && ex.LastAlternateReps.Length > i)
				ex.AlternateReps[i] = ex.LastAlternateReps[i];
			if (ex.HasWeights && ex.LastAlternateWeights != null && ex.LastAlternateWeights.Length > i)
				ex.AlternateWeights[i] = ex.LastAlternateWeights[i];
			if (ex.HasDurations && ex.LastAlternateDurations != null && ex.LastAlternateDurations.Length > i)
				ex.AlternateDurations[i] = ex.LastAlternateDurations[i];
			if (ex.LastNotes != null && ex.LastNotes.Length > i)
				ex.Notes[i] = ex.LastNotes[i];

			if (HasAnyAlternateData(ex, i))
				_expandedAlternates.Add((WorkoutDto.ExerciseIndex, i));
		}
	}

	private async Task OnBackClick()
	{
		if (WorkoutDto is null) return;

		SlidingClass = "slide-from-left";

		if (WorkoutDto.ExerciseIndex > 0)
			WorkoutDto.ExerciseIndex--;

		WorkoutDto.EndTime = DateTimeOffset.Now;
		await BrowserStorage.SetAsync(WorkoutDto.GetBrowserStorageId, WorkoutDto);
	}

	private async Task OnNextClick()
	{
		if (WorkoutDto is null) return;

		SlidingClass = "slide-from-right";

		if (WorkoutDto.ExerciseIndex < WorkoutDto.WorkoutExercises?.Count)
			WorkoutDto.ExerciseIndex++;

		WorkoutDto.EndTime = DateTimeOffset.Now;
		await BrowserStorage.SetAsync(WorkoutDto.GetBrowserStorageId, WorkoutDto);
	}

	private async Task OnSubmitClick()
	{
		if (WorkoutDto is null) return;
		if (Saving) return;
		Saving = true;
		StateHasChanged();

		try
		{
			WorkoutDto.EndTime ??= DateTimeOffset.Now;
			var response = await Http.PostAsJsonAsync("api/workouts", WorkoutDto);

			if (!response.IsSuccessStatusCode)
			{
				Snackbar.Add("Your workout could not be saved. Please try again.", Severity.Error);
				return;
			}

			try
			{
				await BrowserStorage.DeleteAsync(WorkoutDto.GetBrowserStorageId);
			}
			catch { }

			Navigation.NavigateTo("/workouts", forceLoad: true);
		}
		catch
		{
			Snackbar.Add("Your workout could not be saved. Please try again.", Severity.Error);
		}
		finally { Saving = false; }
	}
}
