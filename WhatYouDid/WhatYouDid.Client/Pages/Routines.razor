@page "/routines"
@using WhatYouDid.Shared
@attribute [Authorize]
@rendermode InteractiveWebAssembly

@inject IRoutineService RoutineService
@inject NavigationManager Navigation

<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<PageTitle>Routines</PageTitle>
<MudText Typo="Typo.h4">Routines</MudText>

@if (routines is null)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    @if (!_ready)
    {
        <MudProgressLinear Indeterminate="true" Class="mb-2" />
    }
    <MudStack Spacing="3" Style="@(!_ready ? "pointer-events: none; opacity: 0.6" : "")">
        @foreach (var routine in routines)
        {
            <RoutineCard Name="@routine.Name" RoutineId="@routine.RoutineId" />
        }
    </MudStack>
}

@code {

    [PersistentState]
    public List<RoutineDto>? routines { get; set; }

    bool _ready;

    protected override async Task OnInitializedAsync()
    {
        routines ??= await RoutineService.GetUserRoutinesAsync();
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            _ready = true;
            StateHasChanged();
        }
    }
}
