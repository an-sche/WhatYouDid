@page "/routines"
@using WhatYouDid.Shared
@attribute [Authorize]
@rendermode InteractiveWebAssembly

@inject IRoutineService RoutineService
@inject NavigationManager Navigation

<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<PageTitle>Routines</PageTitle>
<MudText Typo="Typo.h4">Routines</MudText>

@if (routines is null)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudStack Spacing="3">
        @foreach (var routine in routines)
        {
            <RoutineCard Name="@routine.Name" RoutineId="@routine.RoutineId" />
        }
    </MudStack>
}

@code {

    [PersistentState]
    public List<RoutineDto>? routines { get; set; }

    protected override async Task OnInitializedAsync()
    {
        routines ??= await RoutineService.GetUserRoutinesAsync();
    }
}
