@page "/createroutine"

@using WhatYouDid.Shared
@attribute [Authorize]
@rendermode InteractiveWebAssembly

@inject IRoutineService RoutineService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IBrowserStorage BrowserStorage

<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<PageTitle>Create Routine</PageTitle>
<MudText Typo="Typo.h4">Create Routine</MudText>

<div style="width: 560px; max-width: 100%">
		<hr />
		<EditForm Model=@routine OnValidSubmit="OnValidSubmit" OnInvalidSubmit="OnInvalidSubmit" FormName="CreateRoutine" Context="CreateRoutine">

			<DataAnnotationsValidator />
			<ValidationSummary />

			<MudTextField Label="Routine Name" @bind-Value="routine.Name" FullWidth="true" Variant="Variant.Outlined" Class="mb-2" />
			<ValidationMessage For="() => routine.Name" />
			<hr />

			@for (int idx = 0; idx < routine.Exercises.Count; idx++)
			{
				var e = routine.Exercises[idx];
				var i = idx;

				<MudCard Outlined="true" Class="mb-4" data-exercise-card="@_exerciseKeys[i]">
					<MudCardContent>
						<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
							<MudText Typo="Typo.subtitle2">@e.Sequence.</MudText>
							<MudStack Row="true" Spacing="1">
								<MudIconButton Icon="@Icons.Material.Filled.ArrowUpward" Variant="Variant.Outlined" Color="Color.Default" Size="Size.Medium" OnClick="@(() => MoveExerciseUp(e))" Disabled="@(i == 0)" />
								<MudIconButton Icon="@Icons.Material.Filled.ArrowDownward" Variant="Variant.Outlined" Color="Color.Default" Size="Size.Medium" OnClick="@(() => MoveExerciseDown(e))" Disabled="@(i == routine.Exercises.Count - 1)" />
								<MudIconButton Icon="@Icons.Material.Filled.Delete" Variant="Variant.Outlined" Color="Color.Error" Size="Size.Medium" OnClick="@(() => RemoveExercise(e))" />
							</MudStack>
						</MudStack>
						<MudTextField Label="Exercise Name" @bind-Value="e.Name" FullWidth="true" Variant="Variant.Outlined" Class="mb-2" />
						<ValidationMessage For="() => e.Name" />

						<MudTextField Label="Description (optional)" @bind-Value="e.Description" Lines="2" FullWidth="true" Variant="Variant.Outlined" Class="mt-3" />
						<ValidationMessage For="() => e.Description" />

						<MudNumericField T="int" Label="Sets" @bind-Value="e.Sets" Min="1" Max="10" Variant="Variant.Outlined" Class="mt-3" />
						<ValidationMessage For="() => e.Sets" />

						<MudStack Row="true" Spacing="4" Class="mt-3" Style="flex-wrap: wrap">
							<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
								<MudCheckBox @bind-Value="e.HasReps" />
								<MudText>Reps</MudText>
							</MudStack>
							<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
								<MudCheckBox @bind-Value="e.HasWeight" />
								<MudText>Weight</MudText>
							</MudStack>
							<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
								<MudCheckBox @bind-Value="e.HasDuration" />
								<MudText>Duration</MudText>
							</MudStack>
						</MudStack>
					</MudCardContent>
				</MudCard>
			}

			<MudButton OnClick="@AddExercise" StartIcon="@Icons.Material.Filled.AddCircleOutline" Color="Color.Primary" Variant="Variant.Filled" Class="mb-4" FullWidth="true">Add Exercise</MudButton>

			@if (errorMessage is not null)
			{
				<MudAlert Severity="Severity.Error" Class="mb-3">@errorMessage</MudAlert>
			}

			<MudButton ButtonType="ButtonType.Submit" StartIcon="@Icons.Material.Filled.Save" Color="Color.Secondary" Variant="Variant.Filled" Disabled="@Busy" FullWidth="true">Create Routine</MudButton>

		</EditForm>
	</div>



@code {

	private const string DraftKey = "CreateRoutine_Draft";
	private bool _initialized = false;
	private bool Busy = false;
	private string? errorMessage = null;
	private List<string> _exerciseKeys = [Guid.NewGuid().ToString("N")];
	private Dictionary<string, double>? _flipPositions;

	CreateRoutineDto routine = new() {
		Name = string.Empty,
		Exercises = new List<CreateExerciseDto>()
		{
			new CreateExerciseDto()
			{
				Sequence = 1,
				Name = string.Empty,
				Sets = 1,

				HasReps = true,
				HasWeight = true
			}
		},
	};

	async Task OnInvalidSubmit()
	{
		await Task.Yield();
	}

	async Task OnValidSubmit()
	{
		if (Busy) return;
		Busy = true;
		errorMessage = null;

		try
		{
			if (routine.Exercises.Any(e => string.IsNullOrWhiteSpace(e.Name) || e.Name.Trim().Length < 3))
			{
				errorMessage = "All exercises must have a name (at least 3 characters).";
				return;
			}

			var success = await RoutineService.AddRoutineAsync(routine);
			if (!success)
			{
				errorMessage = "Failed to create routine. Please try again.";
				return;
			}

			await BrowserStorage.DeleteAsync(DraftKey);
			Navigation.NavigateTo("routines");
		}
		catch
		{
			errorMessage = "An unexpected error occurred. Please try again.";
		}
		finally
		{
			Busy = false;
		}
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (_flipPositions is not null)
		{
			await JS.InvokeVoidAsync("exerciseCardHelper.animateFlip", _flipPositions);
			_flipPositions = null;
		}

		if (firstRender)
		{
			var draft = await BrowserStorage.GetAsync<CreateRoutineDto>(DraftKey);
			if (draft is not null)
			{
				routine = draft;
				_exerciseKeys = routine.Exercises.Select(_ => Guid.NewGuid().ToString("N")).ToList();
				StateHasChanged();
			}
			_initialized = true;
			return;
		}

		if (_initialized)
		{
			await BrowserStorage.SetAsync(DraftKey, routine);
		}
	}

	void AddExercise()
	{
		routine.Exercises.Add(
			new CreateExerciseDto()
			{
				Sequence = routine.Exercises.Count + 1,
				Name = string.Empty,
				Sets = 1,

				HasReps = true,
				HasWeight = true
			}
		);
		_exerciseKeys.Add(Guid.NewGuid().ToString("N"));
	}

	void RemoveExercise(CreateExerciseDto e)
	{
		int index = routine.Exercises.IndexOf(e);
		if (routine.Exercises.Remove(e))
		{
			_exerciseKeys.RemoveAt(index);
			RenumberExercises();
		}
	}

	async Task MoveExerciseUp(CreateExerciseDto e)
	{
		int index = routine.Exercises.IndexOf(e);
		if (index <= 0) return;
		_flipPositions = await JS.InvokeAsync<Dictionary<string, double>>("exerciseCardHelper.capturePositions");
		routine.Exercises.RemoveAt(index);
		routine.Exercises.Insert(index - 1, e);
		(_exerciseKeys[index], _exerciseKeys[index - 1]) = (_exerciseKeys[index - 1], _exerciseKeys[index]);
		RenumberExercises();
	}

	async Task MoveExerciseDown(CreateExerciseDto e)
	{
		int index = routine.Exercises.IndexOf(e);
		if (index < 0 || index >= routine.Exercises.Count - 1) return;
		_flipPositions = await JS.InvokeAsync<Dictionary<string, double>>("exerciseCardHelper.capturePositions");
		routine.Exercises.RemoveAt(index);
		routine.Exercises.Insert(index + 1, e);
		(_exerciseKeys[index], _exerciseKeys[index + 1]) = (_exerciseKeys[index + 1], _exerciseKeys[index]);
		RenumberExercises();
	}

	void RenumberExercises()
	{
		for (int i = 0; i < routine.Exercises.Count; i++)
			routine.Exercises[i].Sequence = i + 1;
	}

}
