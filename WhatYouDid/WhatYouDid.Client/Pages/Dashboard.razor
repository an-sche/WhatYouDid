@page "/dashboard"
@using WhatYouDid.Shared
@attribute [Authorize]
@rendermode InteractiveWebAssembly

@inject IDashboardService Service

<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<PageTitle>Dashboard</PageTitle>

<MudText Typo="Typo.h4">Dashboard</MudText>

<MudSelect T="int" Value="selectedYear" ValueChanged="ReloadDataAsync" Style="min-width:160px" Variant="Variant.Outlined">
    @foreach (var item in yearItems ?? [new YearItem(0, "All Years")])
    {
        <MudSelectItem Value="@item.Value">@item.Label</MudSelectItem>
    }
</MudSelect>
<br />

@if (dashboard is null)
{
    <MudProgressLinear Indeterminate="true" />
    return;
}
@if (dashboard.TopWorkouts is null || !dashboard.TopWorkouts.Any())
{
    <MudItem xs="12">
        <MudCard>
            <MudCardContent>
                <MudText>No workout data for the selected year(s)</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    return;
}

<MudGrid Class="mb-6">
    @foreach (var w in dashboard.TopWorkouts)
    {
        <MudItem xs="12" sm="6" md="4">
            <MudCard Style="height:150px">
                <MudCardContent>
                    <MudText Typo="Typo.h6">@w.RoutineName</MudText>
                    <MudText Typo="Typo.h3">@w.Count</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">times performed</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }

    <MudItem xs="12" sm="6" md="4">
        <MudCard Style="height:150px">
            <MudCardContent>
                <MudText Typo="Typo.h6">Total Workout Duration</MudText>
                <MudText Typo="Typo.h3">@FormatMinutes(dashboard.TotalWorkoutDuration)</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">sum of all workouts</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="4">
        <MudCard Style="height:150px">
            <MudCardContent>
                <MudText Typo="Typo.h6">Total Reps Completed</MudText>
                <MudText Typo="Typo.h3">@dashboard.TotalReps</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">count of reps</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="4">
        <MudCard Style="height:150px">
            <MudCardContent>
                <MudText Typo="Typo.h6">Total Workouts</MudText>
                <MudText Typo="Typo.h3">@dashboard.TotalWorkouts</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">workouts completed</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    public record YearItem(int Value, string Label);

    [PersistentState]
    public DashboardDto? dashboard { get; set; }

    [PersistentState]
    public List<YearItem>? yearItems { get; set; }

    [PersistentState]
    public int selectedYear { get; set; } // 0 = All Years

    private static string FormatMinutes(int? minutes)
    {
        if (!minutes.HasValue)
            return "-";

        var ts = TimeSpan.FromMinutes(minutes.Value);
        if (ts.TotalHours >= 1)
        {
            return $"{(int)ts.TotalHours}h {ts.Minutes}m";
        }
        return $"{ts.Minutes}m";
    }

    protected override async Task OnInitializedAsync()
    {
        if (yearItems is null)
        {
            var years = await Service.GetActiveYearsAsync();
            yearItems = [new YearItem(0, "All Years"), ..years.Select(y => new YearItem(y, y.ToString()))];
        }
        dashboard ??= await Service.GetDashboardForUserAsync();
    }

    private async Task ReloadDataAsync(int year)
    {
        selectedYear = year;
        try
        {
            dashboard = await Service.GetDashboardForUserAsync(selectedYear == 0 ? null : selectedYear);
        }
        catch
        {
            dashboard = new DashboardDto { TopWorkouts = new List<WorkoutSummaryDto>() };
        }
    }
}
